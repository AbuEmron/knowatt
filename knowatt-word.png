<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<title>Knowatt</title>
<link rel="icon" type="image/png" href="data:image/png;base64," />
<link rel="apple-touch-icon" href="data:image/png;base64," />
<link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{--bg:#0c1320;--bg2:#0a0f1a;--panel:#161f2e;--panel2:#1d2838;--line:#283448;
    --gold:#F5C518;--gold2:#E8A20a;--txt:#eef3f8;--mut:#8a98aa;--mut2:#6d7c90;--good:#37d39a;--bad:#ff5b5b;--rad:18px}
  *{box-sizing:border-box;-webkit-tap-highlight-color:transparent}
  html,body{margin:0;height:100%}
  body{background:#04070d;font-family:'Inter',system-ui,sans-serif;color:var(--txt);display:flex;justify-content:center}
  #phone{width:100%;max-width:430px;min-height:100vh;background:var(--bg);position:relative;display:flex;flex-direction:column;overflow:hidden}
  @media(min-width:470px){#phone{box-shadow:0 0 70px rgba(0,0,0,.65)}}
  #view{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch}
  .pad{padding:4px 18px 24px}.fade{animation:fade .22s ease}@keyframes fade{from{opacity:0}to{opacity:1}}
  .sb{display:flex;justify-content:space-between;align-items:center;padding:13px 20px 4px;font-size:13.5px;font-weight:600}
  .sb .ic{display:flex;gap:5px;align-items:center}.sb svg{width:16px;height:13px;fill:var(--txt)}
  #splash{position:absolute;inset:0;z-index:50;background:radial-gradient(130% 80% at 50% 0%,#16203140 0,#0000 60%),var(--bg2);
    display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:34px;transition:opacity .45s,visibility .45s}
  #splash.hide{opacity:0;visibility:hidden}.trace{position:absolute;inset:0;opacity:.5}
  #splash .mk{width:122px;margin-bottom:4px;filter:drop-shadow(0 10px 26px rgba(245,197,24,.16));z-index:1}
  #splash .wd{width:232px;margin-bottom:46px;z-index:1}
  .sp-btn{font-family:'Poppins';font-weight:700;background:var(--gold);color:#10141a;border:0;border-radius:14px;padding:16px;font-size:16px;cursor:pointer;width:270px;max-width:80vw;z-index:1}
  .sp-btn.dark{background:var(--panel);color:var(--txt);border:1px solid var(--line);margin-top:13px}
  .sp-new{margin-top:20px;font-size:13.5px;color:var(--mut);z-index:1}.sp-new b{color:var(--gold);font-weight:600}
  .hbar{display:flex;align-items:center;gap:12px;padding:6px 18px 2px}.hbar .t{font-family:'Poppins';font-weight:700;font-size:23px;flex:1}
  .icbtn{width:40px;height:40px;border-radius:12px;background:var(--panel);border:1px solid var(--line);display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--txt)}
  .icbtn svg{width:20px;height:20px;stroke:currentColor;fill:none;stroke-width:1.9;stroke-linecap:round;stroke-linejoin:round}
  .welcome{font-size:14px;color:var(--mut)}.name{font-family:'Poppins';font-weight:700;font-size:24px;display:flex;align-items:center;gap:7px;margin-top:1px}.name img{height:21px}
  .rowsb{display:flex;align-items:center;justify-content:space-between;margin:22px 2px 11px}.rowsb .h{font-family:'Poppins';font-weight:600;font-size:15.5px}.rowsb .a{color:var(--gold);font-size:13.5px;font-weight:600;cursor:pointer}
  .card{background:var(--panel);border:1px solid var(--line);border-radius:var(--rad);padding:18px}
  .pgrid{display:flex;align-items:center;gap:18px}.donut{position:relative;flex:0 0 auto}
  .donut .ctr{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center}
  .donut .pc{font-family:'Poppins';font-weight:800;font-size:25px;line-height:1}.donut .lb{font-size:10.5px;color:var(--mut);margin-top:2px}
  .stats{flex:1}.stat{display:flex;justify-content:space-between;align-items:center;padding:6px 0;font-size:14.5px}
  .stat .k{color:var(--mut)}.stat .v{font-family:'Poppins';font-weight:700}.v.good{color:var(--good)}.v.bad{color:var(--bad)}
  .lic{margin-top:13px}.lic .top{display:flex;justify-content:space-between;align-items:flex-start}.lic .lt{font-family:'Poppins';font-weight:700;font-size:16px}.lic .ls{font-size:13px;color:var(--mut);margin-top:2px}
  .chgbtn{font-size:12.5px;font-weight:600;color:var(--gold);background:rgba(245,197,24,.1);border:1px solid rgba(245,197,24,.32);border-radius:9px;padding:6px 12px;cursor:pointer}
  .pbar{height:8px;background:#222d3d;border-radius:8px;overflow:hidden;margin:15px 0 8px}.pbar>i{display:block;height:100%;background:linear-gradient(90deg,var(--gold),var(--gold2));border-radius:8px}
  .lic .meta{display:flex;justify-content:space-between;font-size:12.5px;color:var(--mut)}
  .tiles{display:grid;grid-template-columns:1fr 1fr;gap:13px;margin-top:13px}
  .tile{background:var(--panel);border:1px solid var(--line);border-radius:var(--rad);padding:16px;text-align:left;cursor:pointer;color:var(--txt)}
  .tile .ti{width:30px;height:30px;margin-bottom:11px}.tile .ti svg{width:26px;height:26px;stroke:var(--gold);fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}
  .tile .tt{font-family:'Poppins';font-weight:700;font-size:15.5px}.tile .ts{font-size:12px;color:var(--mut);margin-top:4px;line-height:1.4}
  #nav{display:flex;background:rgba(10,15,25,.94);backdrop-filter:blur(14px);border-top:1px solid var(--line);padding:9px 4px calc(9px + env(safe-area-inset-bottom))}
  #nav.hide{display:none}#nav button{flex:1;background:none;border:0;color:var(--mut2);font-size:10.5px;font-weight:600;font-family:'Inter';cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:4px;padding:3px}
  #nav svg{width:23px;height:23px;stroke:currentColor;fill:none;stroke-width:1.9;stroke-linecap:round;stroke-linejoin:round}#nav button.on{color:var(--gold)}
  .qwrap{display:flex;flex-direction:column;min-height:100%}
  .qhead{display:flex;align-items:center;padding:6px 16px 2px}.qhead .ttl{flex:1;text-align:center;font-family:'Poppins';font-weight:600;font-size:16.5px}
  .qmeta{display:flex;justify-content:space-between;align-items:center;padding:14px 18px 0;font-size:13.5px;color:var(--mut)}.qmeta .tm{display:flex;align-items:center;gap:6px}.qmeta svg{width:15px;height:15px;stroke:currentColor;fill:none;stroke-width:2}
  .qtrack{height:7px;background:#222d3d;border-radius:7px;margin:10px 18px 0;overflow:hidden}.qtrack>i{display:block;height:100%;background:var(--gold);transition:width .3s}
  .qbody{padding:20px 18px 8px;flex:1}.qtext{font-family:'Poppins';font-weight:600;font-size:18.5px;line-height:1.42;margin-bottom:20px}
  .opt{display:flex;align-items:center;gap:13px;width:100%;text-align:left;background:var(--panel);border:1.6px solid var(--line);border-radius:13px;padding:14px 15px;margin-bottom:11px;cursor:pointer;color:var(--txt);font-size:15px;font-weight:500;transition:.13s}
  .opt .ltr{width:28px;height:28px;border-radius:50%;border:1.6px solid var(--line);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;flex:0 0 auto;color:var(--mut)}
  .opt .otext{flex:1}.opt .ck{font-weight:800;font-size:17px}
  .opt.correct{border-color:var(--good);background:rgba(55,211,154,.1)}.opt.correct .ltr{background:var(--good);border-color:var(--good);color:#06321f}.opt.correct .ck{color:var(--good)}
  .opt.wrong{border-color:var(--bad);background:rgba(255,91,91,.08)}.opt.wrong .ltr{background:var(--bad);border-color:var(--bad);color:#fff}.opt.wrong .ck{color:var(--bad)}
  .opt.sel{border-color:var(--gold)}.opt.sel .ltr{border-color:var(--gold);color:var(--gold)}.opt[disabled]{cursor:default}
  .fb{background:var(--panel2);border-radius:13px;padding:15px;margin-top:4px}.fb .ft{display:flex;justify-content:space-between;align-items:center;margin-bottom:7px}.fb .fh{font-family:'Poppins';font-weight:700;font-size:15px}
  .fb.good .fh{color:var(--good)}.fb.bad .fh{color:var(--bad)}.fb .bm{cursor:pointer;color:var(--mut)}.fb .bm svg{width:18px;height:18px;stroke:currentColor;fill:none;stroke-width:1.9}.fb .bm.on svg{fill:var(--gold);stroke:var(--gold)}
  .fb .fw{font-size:13.5px;line-height:1.55;color:#cdd7e2}.fb .fw b{color:var(--gold)}
  .ref{display:inline-block;margin-top:9px;font-size:11.5px;font-weight:700;color:var(--gold);background:rgba(245,197,24,.1);padding:4px 9px;border-radius:7px}
  .qbtns{display:flex;gap:11px;padding:12px 18px calc(16px + env(safe-area-inset-bottom));margin-top:auto}
  .qbtns button{flex:1;border:0;border-radius:13px;padding:15px;font-family:'Poppins';font-weight:700;font-size:15px;cursor:pointer}.qbtns .dark{background:var(--panel);color:var(--txt);border:1px solid var(--line)}.qbtns .gold{background:var(--gold);color:#10141a}
  .search{display:flex;align-items:center;gap:10px;background:var(--panel);border:1px solid var(--line);border-radius:13px;padding:13px 14px;margin:6px 0 14px}.search svg{width:18px;height:18px;stroke:var(--mut);fill:none;stroke-width:2}.search input{flex:1;background:none;border:0;outline:none;color:var(--txt);font-size:14.5px;font-family:'Inter'}
  .toggle{display:flex;gap:9px;margin-bottom:16px}.toggle button{flex:1;border:1px solid var(--line);background:var(--panel);color:var(--mut);font-weight:600;font-family:'Poppins';font-size:13.5px;border-radius:11px;padding:11px;cursor:pointer}.toggle button.on{background:var(--gold);color:#10141a;border-color:var(--gold)}
  .arow{display:flex;align-items:center;gap:13px;padding:13px 4px;border-bottom:1px solid var(--line);cursor:pointer}
  .arow .ai{width:30px;height:30px;flex:0 0 auto}.arow .ai svg{width:24px;height:24px;stroke:var(--gold);fill:none;stroke-width:1.7;stroke-linecap:round;stroke-linejoin:round}
  .arow .an{font-family:'Poppins';font-weight:600;font-size:15px}.arow .as{font-size:12px;color:var(--mut);margin-top:2px;line-height:1.35}.arow .ap{font-size:13px;color:var(--mut);white-space:nowrap}.arow .cv{color:var(--mut2);font-size:20px}
  .mcard{display:flex;align-items:center;gap:14px;background:var(--panel);border:1px solid var(--line);border-radius:14px;padding:15px;margin-bottom:11px;cursor:pointer}
  .mcard .mi{width:42px;height:42px;border-radius:11px;background:rgba(245,197,24,.1);display:flex;align-items:center;justify-content:center;flex:0 0 auto}
  .mcard .mi svg{width:22px;height:22px;stroke:var(--gold);fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}
  .mcard .mn{flex:1}.mcard .mt2{font-family:'Poppins';font-weight:700;font-size:15px}.mcard .ms{font-size:12.5px;color:var(--mut);margin-top:2px}.mcard .cv{color:var(--mut2);font-size:20px}
  .mock{display:flex;flex-direction:column;min-height:100%;align-items:center;text-align:center;padding:20px 26px calc(20px + env(safe-area-inset-bottom))}
  .mock .big-ic{width:96px;height:96px;border-radius:26px;background:rgba(245,197,24,.1);border:1px solid rgba(245,197,24,.25);display:flex;align-items:center;justify-content:center;margin:24px 0 22px}
  .mock .big-ic svg{width:46px;height:46px;stroke:var(--gold);fill:none;stroke-width:1.7;stroke-linecap:round;stroke-linejoin:round}
  .mock .mt{font-family:'Poppins';font-weight:700;font-size:22px;line-height:1.25}.mlist{width:100%;max-width:300px;margin:24px 0 0;text-align:left}
  .mli{display:flex;align-items:center;gap:13px;padding:11px 0;font-size:15px}.mli svg{width:20px;height:20px;stroke:var(--gold);fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;flex:0 0 auto}.mock .sp-btn{margin-top:auto;width:100%}
  .seg{display:flex;align-items:center;gap:6px;font-size:13px;font-weight:600;color:var(--txt);background:var(--panel);border:1px solid var(--line);border-radius:10px;padding:8px 12px}
  .chart{position:relative;height:160px;margin-top:4px}.chart .yl{position:absolute;left:0;font-size:10.5px;color:var(--mut2);transform:translateY(-50%)}
  .chart .grid{position:absolute;left:34px;right:0;border-top:1px dashed #233044}.chart svg{position:absolute;left:34px;right:0;top:0;bottom:0;width:calc(100% - 34px)}
  .xlab{display:flex;justify-content:space-between;padding:6px 0 0 34px;font-size:10.5px;color:var(--mut2)}
  .article h2{font-family:'Poppins';font-weight:700;font-size:21px;margin:2px 0 10px}.article p{font-size:15px;line-height:1.62;color:#d6dee7;margin:0 0 13px}
  .article ul{margin:0 0 13px;padding-left:18px}.article li{font-size:14.5px;line-height:1.55;margin-bottom:6px;color:#d0d9e3}
  .keybox{background:var(--panel2);border:1px solid var(--line);border-radius:12px;padding:15px;margin:6px 0 16px}.keybox .kh{font-family:'Poppins';font-weight:700;font-size:12.5px;color:var(--gold);text-transform:uppercase;letter-spacing:.05em;margin-bottom:9px}
  .btn{display:block;width:100%;border:0;border-radius:13px;padding:15px;font-family:'Poppins';font-weight:700;font-size:15px;cursor:pointer;margin-top:13px}.btn.gold{background:var(--gold);color:#10141a}.btn.ghost{background:var(--panel);color:var(--txt);border:1px solid var(--line)}
  .fld{margin-bottom:12px}.fld label{display:block;font-size:12.5px;color:var(--mut);font-weight:600;margin-bottom:6px}
  .fld input,.fld select{width:100%;background:var(--panel2);border:1px solid var(--line);border-radius:10px;padding:13px;color:var(--txt);font-size:15px;font-family:'Inter'}.fld input:focus,.fld select:focus{outline:none;border-color:var(--gold)}
  .twocol{display:grid;grid-template-columns:1fr 1fr;gap:10px}.out{background:var(--panel2);border:1px solid var(--line);border-radius:11px;padding:14px;margin-top:6px;font-size:14px}.out .b2{font-family:'Poppins';font-weight:800;font-size:20px;color:var(--gold)}
  .disc{font-size:11px;color:var(--mut2);line-height:1.6;margin-top:10px}
  .flash{display:flex;flex-direction:column;min-height:100%;padding:18px 18px calc(18px + env(safe-area-inset-bottom))}
  .fcard{flex:1;background:var(--panel);border:1px solid var(--line);border-radius:20px;padding:26px;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;cursor:pointer;margin:8px 0 14px;min-height:300px}
  .fcard .fq{font-family:'Poppins';font-weight:600;font-size:19px;line-height:1.4}.fcard .fa{font-size:16px;color:var(--good);font-weight:700;margin-bottom:10px}.fcard .fhint{font-size:12.5px;color:var(--mut2);margin-top:18px}.fcard .fwhy{font-size:13.5px;color:#cdd7e2;line-height:1.55}.fcard .fwhy b{color:var(--gold)}
  .ob{display:flex;flex-direction:column;min-height:100%;padding:30px 26px calc(24px + env(safe-area-inset-bottom));justify-content:center}
  .ob h1{font-family:'Poppins';font-weight:800;font-size:25px;margin:0 0 6px}.ob p{color:var(--mut);font-size:14px;margin:0 0 26px}
  .chiprow{display:flex;gap:9px;flex-wrap:wrap;margin-bottom:6px}.lvl{border:1px solid var(--line);background:var(--panel2);color:var(--mut);font-weight:600;font-family:'Poppins';font-size:13.5px;border-radius:11px;padding:11px 14px;cursor:pointer;flex:1}.lvl.on{background:var(--gold);color:#10141a;border-color:var(--gold)}
  .gterm{background:var(--panel);border:1px solid var(--line);border-radius:13px;padding:14px;margin-bottom:10px}.gterm .gt{font-family:'Poppins';font-weight:700;font-size:15px;color:var(--gold);margin-bottom:5px}.gterm .gd{font-size:13.5px;color:#cdd7e2;line-height:1.5}
  .empty{color:var(--mut);padding:24px 4px;text-align:center}
</style>

<link rel="manifest" href="/manifest.webmanifest" />
<meta name="theme-color" content="#0b1f3a" />
<link rel="apple-touch-icon" href="/assets/knowatt-icon-rounded.png" />
</head>
<body>
<div id="phone">
  <div id="splash">
    <svg class="trace" viewBox="0 0 430 800" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <g fill="none" stroke="#1c2942" stroke-width="1.2"><path d="M-10 120 H120 V250 H260"/><path d="M-10 560 H90 V430 H230"/><path d="M440 200 H320 V330 H210"/><path d="M440 640 H340 V500 H250"/></g>
      <g fill="#22324d"><circle cx="120" cy="250" r="3"/><circle cx="90" cy="430" r="3"/><circle cx="320" cy="330" r="3"/><circle cx="340" cy="500" r="3"/></g></svg>
    <img class="mk" src="data:image/png;base64," alt=""><img class="wd" src="data:image/png;base64," alt="Knowatt — Test Prep for Electrical Licensing">
    <button class="sp-btn" onclick="enter()">Start Practicing</button>
    <button class="sp-btn dark" onclick="enter()">Sign In</button>
    <div class="sp-new">New here? <b>Create Account</b></div>
  </div>
  <div id="view"></div>
  <div id="nav"></div>
</div>
<script>
/* ===================== DATA ===================== */
const ICON="data:image/png;base64,",MARK="data:image/png;base64,";
const CATS=["Theory","Loads & OCPD","Grounding & Bonding","Conductors","Voltage Drop","GFCI / AFCI","Raceway & Boxes","Motors","3-Phase & Transformers","Definitions","Code Calculations","Code & Editions"];
const QUESTIONS=[
/* Theory */
{id:"t1",cat:"Theory",q:"A 120 V circuit supplies a load drawing 12 A. What is the resistance?",opts:["10 \u03A9","0.1 \u03A9","132 \u03A9","1,440 \u03A9"],correct:0,why:"<b>R = V \u00F7 I</b> = 120 \u00F7 12 = 10 \u03A9.",ref:"Ohm's Law"},
{id:"t2",cat:"Theory",q:"How much power does a 120 V, 0.5 A lamp consume?",opts:["60 W","240 W","0.6 W","120.5 W"],correct:0,why:"<b>P = V \u00D7 I</b> = 120 \u00D7 0.5 = 60 W.",ref:"Power"},
{id:"t3",cat:"Theory",q:"Two 100 \u03A9 resistors in parallel total\u2026",opts:["50 \u03A9","200 \u03A9","100 \u03A9","0 \u03A9"],correct:0,why:"Equal parallel resistors: 100 \u00F7 2 = 50 \u03A9. Parallel total is always <b>less than the smallest branch</b>.",ref:"Series / Parallel"},
{id:"t4",cat:"Theory",q:"A 5 A current flows through a 24 \u03A9 element. Power dissipated?",opts:["600 W","120 W","4.8 W","29 W"],correct:0,why:"<b>P = I\u00B2 \u00D7 R</b> = 25 \u00D7 24 = 600 W.",ref:"Power"},
{id:"t5",cat:"Theory",q:"If voltage is constant and resistance doubles, current will\u2026",opts:["be cut in half","double","stay the same","quadruple"],correct:0,why:"I = V \u00F7 R \u2014 doubling R <b>halves</b> current.",ref:"Ohm's Law"},
{id:"t6",cat:"Theory",q:"Two 10 \u03A9 resistors in series total\u2026",opts:["20 \u03A9","5 \u03A9","10 \u03A9","100 \u03A9"],correct:0,why:"Series resistances <b>add</b>: 10 + 10 = 20 \u03A9.",ref:"Series / Parallel"},
{id:"t7",cat:"Theory",q:"In a series circuit, the current is\u2026",opts:["the same through every component","different at each component","zero","highest at the source"],correct:0,why:"Series has one path, so <b>current is identical</b> everywhere; voltage divides across components.",ref:"Series / Parallel"},
{id:"t8",cat:"Theory",q:"In a parallel circuit, the voltage across each branch is\u2026",opts:["the same on every branch","divided among branches","always zero","highest on the first branch"],correct:0,why:"Parallel branches share the same two nodes, so <b>voltage is the same</b>; current divides.",ref:"Series / Parallel"},
{id:"t9",cat:"Theory",q:"Real (true) power equals apparent power multiplied by\u2026",opts:["the power factor","the voltage","\u221A3","the resistance"],correct:0,why:"<b>P (W) = VA \u00D7 power factor</b>. A pf of 1.0 means all apparent power does real work.",ref:"Power Factor"},
{id:"t10",cat:"Theory",q:"A 240 V heater rated 4,800 W draws how much current?",opts:["20 A","10 A","2 A","1,152 A"],correct:0,why:"<b>I = P \u00F7 V</b> = 4,800 \u00F7 240 = 20 A.",ref:"Power"},
{id:"t11",cat:"Theory",q:"All else equal, a longer conductor has\u2026",opts:["more resistance","less resistance","no resistance","more voltage"],correct:0,why:"Resistance is proportional to length \u2014 longer wire, <b>more resistance</b> and more voltage drop.",ref:"Conductor Resistance"},
{id:"t12",cat:"Theory",q:"Three 60 W lamps in parallel on 120 V draw a total of\u2026",opts:["1.5 A","0.5 A","4.5 A","180 A"],correct:0,why:"Each draws 60 \u00F7 120 = 0.5 A; three in parallel = <b>1.5 A</b> total.",ref:"Power"},
{id:"t13",cat:"Theory",q:"A 1,500 W load running 4 hours uses how much energy?",opts:["6 kWh","1.5 kWh","375 Wh","6,000 kWh"],correct:0,why:"Energy = power \u00D7 time = 1.5 kW \u00D7 4 h = <b>6 kWh</b>.",ref:"Energy"},
{id:"t14",cat:"Theory",q:"For the same size and length, copper compared to aluminum has\u2026",opts:["lower resistance","higher resistance","the same resistance","no resistance"],correct:0,why:"Copper is the better conductor, so for equal size it has <b>lower resistance</b> (and higher ampacity).",ref:"Conductor Material"},
{id:"t15",cat:"Theory",q:"As a copper conductor heats up, its resistance generally\u2026",opts:["increases","decreases","stays constant","drops to zero"],correct:0,why:"Metals have a positive temperature coefficient \u2014 resistance <b>rises with temperature</b>.",ref:"Conductor Resistance"},
/* Loads & OCPD */
{id:"l1",cat:"Loads & OCPD",q:"A continuous load draws 16 A. Minimum conductor ampacity and OCPD?",opts:["20 A","16 A","24 A","32 A"],correct:0,why:"Continuous loads at <b>125%</b>: 16 \u00D7 1.25 = 20 A. (125%, not 150% \u2014 a common app error.)",ref:"210.19(A)/210.20(A)"},
{id:"l2",cat:"Loads & OCPD",q:"10 A noncontinuous + 12 A continuous load. Minimum conductor ampacity?",opts:["25 A","22 A","27.5 A","30 A"],correct:0,why:"100% noncontinuous + 125% continuous: 10 + 15 = <b>25 A</b>.",ref:"210.19(A)"},
{id:"l3",cat:"Loads & OCPD",q:"A 'continuous load' is one expected to run\u2026",opts:["3 hours or more","1 hour or more","8 hours","24 hours"],correct:0,why:"Maximum current expected to continue for <b>3 hours or more</b>.",ref:"Article 100"},
{id:"l4",cat:"Loads & OCPD",q:"Maximum continuous load on a standard 20 A breaker?",opts:["16 A","20 A","25 A","18 A"],correct:0,why:"20 \u00F7 1.25 = 16 A \u2014 the familiar <b>80% rule</b>.",ref:"210.20(A)"},
{id:"l5",cat:"Loads & OCPD",eds:["2017","2020","2023"],q:"Dwelling general lighting load is calculated at how many VA per square foot?",opts:["3 VA","1 VA","5 VA","10 VA"],correct:0,why:"General lighting for dwellings is figured at <b>3 VA/ft²</b> through the 2023 NEC.",ref:"220.12"},
{id:"l5b",cat:"Loads & OCPD",eds:["2026"],q:"Under the 2026 NEC, dwelling general lighting is calculated at how many VA per square foot?",opts:["2 VA","3 VA","1 VA","5 VA"],correct:0,why:"The 2026 NEC cut dwelling general lighting to <b>2 VA/ft²</b> (down from 3) to reflect efficient LED lighting, and moved load calcs to Article 120.",ref:"Article 120 (2026)"},
{id:"l6",cat:"Loads & OCPD",q:"A dwelling kitchen requires at least how many small-appliance branch circuits?",opts:["2","1","3","4"],correct:0,why:"At least <b>two</b> 20 A small-appliance branch circuits serve the kitchen/dining areas.",ref:"210.11(C)(1)"},
{id:"l7",cat:"Loads & OCPD",q:"A dwelling laundry area requires at least\u2026",opts:["one 20 A branch circuit","one 15 A circuit","two 20 A circuits","no dedicated circuit"],correct:0,why:"At least <b>one 20 A</b> laundry branch circuit is required.",ref:"210.11(C)(2)"},
{id:"l8",cat:"Loads & OCPD",q:"Dwelling bathroom receptacles require at least\u2026",opts:["one 20 A branch circuit","one 15 A circuit","two circuits","a 30 A circuit"],correct:0,why:"At least <b>one 20 A</b> branch circuit supplies bathroom receptacle(s).",ref:"210.11(C)(3)"},
{id:"l9",cat:"Loads & OCPD",q:"Which is NOT a standard overcurrent device rating?",opts:["65 A","60 A","70 A","90 A"],correct:0,why:"Standard ratings jump 60 \u2192 70. <b>65 A is not standard</b>.",ref:"240.6(A)"},
{id:"l10",cat:"Loads & OCPD",q:"A 24 A continuous load needs a minimum OCPD of\u2026",opts:["30 A","25 A","24 A","40 A"],correct:0,why:"24 \u00D7 1.25 = 30 A; 30 A is the next standard size at or above that.",ref:"210.20(A)/240.6"},
{id:"l11",cat:"Loads & OCPD",q:"When a conductor's ampacity doesn't match a standard OCPD size (\u2264800 A), you may\u2026",opts:["round up to the next standard size","round down only","use any size","double the size"],correct:0,why:"You may use the <b>next higher standard size</b> for circuits \u2264800 A under the conditions of this rule.",ref:"240.4(B)"},
{id:"l12",cat:"Loads & OCPD",q:"In a dwelling load calc, each small-appliance and laundry circuit is figured at\u2026",opts:["1,500 VA","1,000 VA","500 VA","3,000 VA"],correct:0,why:"Each is counted at <b>1,500 VA</b> before demand factors.",ref:"220.52"},
{id:"l13",cat:"Loads & OCPD",q:"A general-use receptacle outlet is generally figured at how many VA?",opts:["180 VA","120 VA","360 VA","90 VA"],correct:0,why:"Each general receptacle outlet is calculated at <b>180 VA</b> in non-dwelling load calcs.",ref:"220.14(I)"},
/* Grounding & Bonding */
{id:"g1",cat:"Grounding & Bonding",q:"Which conductor carries fault current back to the source to trip the breaker?",opts:["Equipment grounding conductor (EGC)","Grounding electrode conductor","Grounded (neutral) conductor","Ungrounded conductor"],correct:0,why:"The <b>EGC</b> is the low-impedance fault path back to the source. Earth is not that path.",ref:"250.4(A)(5)"},
{id:"g2",cat:"Grounding & Bonding",q:"The primary purpose of bonding is to\u2026",opts:["create an effective ground-fault current path","connect the system to earth","limit lightning voltage","reduce voltage drop"],correct:0,why:"<b>Bonding</b> joins metal parts so they're continuous and can carry fault current.",ref:"250.90/250.4(A)(3)"},
{id:"g3",cat:"Grounding & Bonding",q:"Can the earth serve as the sole effective ground-fault current path?",opts:["No \u2014 its impedance is too high","Yes, if rods are 8 ft deep","Yes, in dry soil","Only over 400 A"],correct:0,why:"Earth impedance is too high/variable to trip an OCPD. That's the <b>EGC's</b> job.",ref:"250.4(A)(5)"},
{id:"g4",cat:"Grounding & Bonding",q:"The grounding electrode conductor (GEC) connects the system to\u2026",opts:["the grounding electrode (earth)","every device box","the neutral bus only","the largest motor"],correct:0,why:"The GEC ties the system to the electrode \u2014 rod, water pipe, or Ufer.",ref:"250.24"},
{id:"g5",cat:"Grounding & Bonding",q:"The main bonding jumper connects the grounded (neutral) conductor to\u2026",opts:["the equipment/enclosure and EGC at the service","the rod only","each subpanel neutral","the largest feeder"],correct:0,why:"The <b>main bonding jumper</b> bonds the neutral to the enclosure/EGC at the service \u2014 the one neutral-ground bond.",ref:"250.24(B)/250.28"},
{id:"g6",cat:"Grounding & Bonding",q:"The 'grounded conductor' in a typical system is the\u2026",opts:["neutral","hot","ground rod","EGC"],correct:0,why:"The <b>grounded conductor is the neutral</b> (white/gray). Don't confuse it with the grounding (EGC) conductor.",ref:"Article 100"},
{id:"g7",cat:"Grounding & Bonding",q:"The minimum size of an equipment grounding conductor is based on\u2026",opts:["the rating of the overcurrent device","the length of the run","the load voltage","the conduit size"],correct:0,why:"The EGC is sized from the <b>OCPD rating</b> protecting the circuit.",ref:"250.122"},
{id:"g8",cat:"Grounding & Bonding",q:"Where the only electrode is a ground rod, the GEC is not required to be larger than\u2026",opts:["6 AWG copper","4 AWG copper","2 AWG copper","1/0 copper"],correct:0,why:"A GEC to a rod (or to any made electrode portion) need not exceed <b>6 AWG copper</b>.",ref:"250.66(A)"},
{id:"g9",cat:"Grounding & Bonding",q:"If a single ground rod exceeds 25 ohms to earth, the NEC requires\u2026",opts:["a supplemental electrode","a bigger GEC","a GFCI","nothing more"],correct:0,why:"A single rod over 25 \u03A9 must be augmented with <b>one additional electrode</b>.",ref:"250.53(A)(2)"},
{id:"g10",cat:"Grounding & Bonding",q:"The neutral and ground should be bonded together at\u2026",opts:["the service only (one point)","every subpanel","each receptacle","both ends of every feeder"],correct:0,why:"The neutral-to-ground bond is made at <b>one point \u2014 the service</b>. Downstream neutrals stay isolated.",ref:"250.24(A)(5)"},
{id:"g11",cat:"Grounding & Bonding",q:"An equipment grounding conductor may be identified by\u2026",opts:["green, green/yellow, or bare","white","gray","blue"],correct:0,why:"EGCs are <b>green, green-with-yellow-stripe, or bare</b>. White/gray = grounded (neutral).",ref:"250.119"},
{id:"g12",cat:"Grounding & Bonding",q:"In a downstream subpanel, the neutral bus must be\u2026",opts:["isolated from the equipment ground","bonded to ground","removed","doubled"],correct:0,why:"Subpanel neutrals are <b>isolated</b> from the enclosure/EGC so neutral current doesn't ride on grounding paths.",ref:"250.24(A)(5)/408.40"},
/* Conductors */
{id:"c1",cat:"Conductors",q:"Small-conductor rule: max OCPD for 12 AWG copper?",opts:["20 A","25 A","30 A","15 A"],correct:0,why:"<b>240.4(D)</b> caps 12 AWG Cu at 20 A.",ref:"240.4(D)"},
{id:"c2",cat:"Conductors",q:"Max OCPD for 14 AWG copper?",opts:["15 A","20 A","10 A","25 A"],correct:0,why:"14 AWG Cu is limited to <b>15 A</b>.",ref:"240.4(D)"},
{id:"c3",cat:"Conductors",q:"Max OCPD for 10 AWG copper?",opts:["30 A","25 A","40 A","20 A"],correct:0,why:"10 AWG Cu is limited to <b>30 A</b>.",ref:"240.4(D)"},
{id:"c4",cat:"Conductors",q:"Unless marked otherwise, terminations on equipment \u2264100 A use which temp column?",opts:["60 \u00B0C","75 \u00B0C","90 \u00B0C","105 \u00B0C"],correct:0,why:"Default <b>60 \u00B0C</b> for \u2264100 A / 14\u20131 AWG unless equipment is listed/marked for higher.",ref:"110.14(C)(1)"},
{id:"c5",cat:"Conductors",q:"More than three current-carrying conductors in a raceway means ampacity must be\u2026",opts:["adjusted downward","increased","unchanged","doubled"],correct:0,why:"Bundling traps heat, so <b>adjustment factors</b> reduce ampacity.",ref:"310.15(C)(1)"},
{id:"c6",cat:"Conductors",q:"The smallest conductor permitted to be run in parallel is\u2026",opts:["1/0 AWG","8 AWG","4 AWG","250 kcmil"],correct:0,why:"Parallel conductors must be <b>1/0 AWG or larger</b> (with limited exceptions).",ref:"310.10(G)"},
{id:"c7",cat:"Conductors",q:"THHN insulation is rated for what temperature in dry locations?",opts:["90 \u00B0C","75 \u00B0C","60 \u00B0C","105 \u00B0C"],correct:0,why:"THHN is a <b>90 \u00B0C</b> dry/damp insulation.",ref:"Table 310.4"},
{id:"c8",cat:"Conductors",q:"THWN insulation is rated for what temperature in wet locations?",opts:["75 \u00B0C","90 \u00B0C","60 \u00B0C","110 \u00B0C"],correct:0,why:"THWN is rated <b>75 \u00B0C wet</b> (THWN-2 is 90 \u00B0C wet).",ref:"Table 310.4"},
{id:"c9",cat:"Conductors",q:"For the same size, aluminum compared to copper has\u2026",opts:["lower ampacity","higher ampacity","the same ampacity","no ampacity"],correct:0,why:"Aluminum's higher resistance gives it <b>lower ampacity</b> than copper of the same size.",ref:"Ampacity"},
{id:"c10",cat:"Conductors",q:"The small-conductor rule (240.4(D)) applies to which sizes?",opts:["14, 12, and 10 AWG","all sizes","8 AWG and larger","only 14 AWG"],correct:0,why:"The fixed caps apply to <b>14, 12, and 10 AWG</b>; larger conductors use their table ampacity.",ref:"240.4(D)"},
{id:"c11",cat:"Conductors",q:"A neutral carrying only the unbalanced current of other conductors is\u2026",opts:["not counted as a current-carrying conductor","always counted","counted as two","ignored entirely"],correct:0,why:"Such a neutral is <b>not counted</b> for conductor-fill adjustment (harmonic/nonlinear loads change this).",ref:"310.15(E)"},
{id:"c12",cat:"Conductors",q:"A conductor's maximum operating temperature is set by its\u2026",opts:["insulation rating","color","length","breaker"],correct:0,why:"The <b>insulation temperature rating</b> (60/75/90 \u00B0C) sets the ceiling for the conductor.",ref:"310.14"},
/* Voltage Drop */
{id:"v1",cat:"Voltage Drop",q:"Recommended max voltage drop for a branch circuit (informational note)?",opts:["3%","5%","10%","2%"],correct:0,why:"Recommends \u22643% branch, \u22645% total. A <b>recommendation</b>, not a mandate.",ref:"210.19(A) Info Note"},
{id:"v2",cat:"Voltage Drop",q:"In Vd = (2 \u00D7 K \u00D7 I \u00D7 L) \u00F7 CM, the factor of 2 accounts for\u2026",opts:["current out and back on two conductors","a safety margin","percent conversion","three-phase"],correct:0,why:"Single-phase counts length <b>both ways</b>. Three-phase uses \u00D71.732.",ref:"Voltage Drop"},
{id:"v3",cat:"Voltage Drop",q:"Doubling a circuit's one-way length will\u2026",opts:["double the voltage drop","halve it","not change it","square it"],correct:0,why:"Drop is <b>proportional to length</b>.",ref:"Voltage Drop"},
{id:"v4",cat:"Voltage Drop",q:"The multiplier in the three-phase voltage-drop formula is\u2026",opts:["1.732","2","3","1.414"],correct:0,why:"Three-phase uses <b>\u221A3 \u2248 1.732</b> instead of the 2 used for single-phase.",ref:"Voltage Drop"},
{id:"v5",cat:"Voltage Drop",q:"Compared to copper, aluminum's higher K value (~21.2) means\u2026",opts:["more voltage drop for the same size","less drop","no difference","no current"],correct:0,why:"Higher K \u2192 <b>more voltage drop</b> for the same size, length, and load.",ref:"Voltage Drop"},
{id:"v6",cat:"Voltage Drop",q:"To reduce voltage drop on a long run, you typically\u2026",opts:["up-size the conductor","down-size it","add a smaller breaker","lower the voltage"],correct:0,why:"A larger conductor has more circular mils \u2192 lower resistance \u2192 <b>less drop</b>.",ref:"Voltage Drop"},
{id:"v7",cat:"Voltage Drop",q:"Doubling the load current (same conductor/length) changes the drop how?",opts:["doubles it","halves it","no change","quarters it"],correct:0,why:"Drop is <b>proportional to current</b> \u2014 twice the amps, twice the drop.",ref:"Voltage Drop"},
{id:"v8",cat:"Voltage Drop",q:"Recommended max total voltage drop (feeder + branch) is\u2026",opts:["5%","3%","8%","10%"],correct:0,why:"The combined recommendation is <b>\u22645% total</b> (with \u22643% on the branch).",ref:"215.2(A) Info Note"},
/* GFCI / AFCI */
{id:"f1",cat:"GFCI / AFCI",q:"A GFCI primarily protects against\u2026",opts:["electric shock to people","arc faults / fire","voltage drop","overloads"],correct:0,why:"It senses current imbalance and trips to <b>protect people</b> from shock.",ref:"Article 100/210.8"},
{id:"f2",cat:"GFCI / AFCI",q:"A Class A GFCI trips at about what ground-fault current?",opts:["4\u20136 mA","15\u201320 A","30 mA","100 mA"],correct:0,why:"Class A trips at <b>4\u20136 mA</b>.",ref:"GFCI (Class A)"},
{id:"f3",cat:"GFCI / AFCI",q:"An AFCI is designed mainly to protect against\u2026",opts:["arc faults that start fires","ground faults to people","lightning","harmonics"],correct:0,why:"AFCIs detect dangerous <b>arcing</b> and de-energize to reduce fire risk.",ref:"210.12"},
{id:"f4",cat:"GFCI / AFCI",q:"Which dwelling location is NOT specifically called out for GFCI protection?",opts:["A bedroom lighting outlet","A bathroom","An outdoor receptacle","A garage receptacle"],correct:0,why:"GFCI targets wet/grounded areas \u2014 baths, kitchens, garages, outdoors, basements. A <b>bedroom lighting outlet</b> is an AFCI concern, not GFCI.",ref:"210.8(A)"},
{id:"f5",cat:"GFCI / AFCI",q:"AFCI protection is broadly required for 120 V, 15/20 A circuits in\u2026",opts:["dwelling living/sleeping areas","outdoor receptacles only","industrial feeders","service conductors"],correct:0,why:"AFCIs cover most 120 V 15/20 A branch circuits serving <b>dwelling living and sleeping areas</b>.",ref:"210.12"},
{id:"f6",cat:"GFCI / AFCI",q:"How often should a GFCI device be tested?",opts:["Monthly","Yearly","Never","Daily"],correct:0,why:"Manufacturers recommend testing the device <b>monthly</b> with the TEST button.",ref:"GFCI Maintenance"},
{id:"f7",cat:"GFCI / AFCI",q:"Receptacles serving dwelling kitchen countertops must be\u2026",opts:["GFCI protected","AFCI only","ungrounded","30 A"],correct:0,why:"Countertop receptacles require <b>GFCI</b> protection.",ref:"210.8(A)(6)"},
/* Raceway & Boxes */
{id:"r1",cat:"Raceway & Boxes",q:"Maximum conduit fill for three or more conductors?",opts:["40%","31%","53%","60%"],correct:0,why:"Chapter 9, Table 1: 1 = 53%, 2 = 31%, <b>3+ = 40%</b>.",ref:"Ch. 9, Table 1"},
{id:"r2",cat:"Raceway & Boxes",q:"In box fill, a single device yoke counts as\u2026",opts:["2 conductor volumes","1 volume","0","4 volumes"],correct:0,why:"A device/yoke counts as <b>twice</b> the volume of the largest conductor on it.",ref:"314.16(B)(4)"},
{id:"r3",cat:"Raceway & Boxes",q:"A conductor passing through a box unbroken counts as\u2026",opts:["one volume","two volumes","zero","half"],correct:0,why:"Each conductor passing through or terminating counts <b>once</b>.",ref:"314.16(B)(1)"},
{id:"r4",cat:"Raceway & Boxes",q:"Max total bend between pull points in a raceway run?",opts:["360\u00B0","180\u00B0","90\u00B0","720\u00B0"],correct:0,why:"No more than <b>360\u00B0</b> total (e.g., four quarter-bends) between pull points.",ref:"358.26 (and similar)"},
{id:"r5",cat:"Raceway & Boxes",q:"EMT must be securely fastened within what distance of each box?",opts:["3 ft","6 ft","10 ft","1 ft"],correct:0,why:"Secure EMT within <b>3 ft</b> of each box, plus every 10 ft.",ref:"358.30"},
{id:"r6",cat:"Raceway & Boxes",q:"In box fill, all equipment grounding conductors collectively count as\u2026",opts:["one conductor volume","one per EGC","two volumes","zero"],correct:0,why:"All EGCs together count as a <b>single</b> conductor volume (largest present).",ref:"314.16(B)(5)"},
{id:"r7",cat:"Raceway & Boxes",q:"Internal cable clamps in a box count as\u2026",opts:["one conductor volume total","one each","two volumes","zero"],correct:0,why:"One or more clamps count as a <b>single</b> conductor volume (largest conductor in the box).",ref:"314.16(B)(2)"},
{id:"r8",cat:"Raceway & Boxes",q:"Maximum conduit fill for exactly two conductors?",opts:["31%","40%","53%","60%"],correct:0,why:"Two conductors = <b>31%</b> fill.",ref:"Ch. 9, Table 1"},
{id:"r9",cat:"Raceway & Boxes",q:"Maximum conduit fill for a single conductor?",opts:["53%","40%","31%","100%"],correct:0,why:"One conductor = <b>53%</b> fill.",ref:"Ch. 9, Table 1"},
/* Motors */
{id:"m1",cat:"Motors",q:"For sizing motor branch-circuit conductors, use\u2026",opts:["table full-load current (FLC)","nameplate FLA","locked-rotor current","breaker rating"],correct:0,why:"Conductors size from the <b>table FLC</b>; nameplate FLA is for overload sizing.",ref:"430.6(A)"},
{id:"m2",cat:"Motors",q:"Conductors for a single continuous-duty motor must be at least\u2026",opts:["125% of FLC","100% of FLC","80% of FLC","250% of FLC"],correct:0,why:"\u2265<b>125%</b> of the table FLC.",ref:"430.22"},
{id:"m3",cat:"Motors",q:"Motor running overload protection is typically set at\u2026",opts:["115\u2013125% of nameplate FLA","250% of FLC","80% of FLC","600% of FLC"],correct:0,why:"Overloads protect at <b>115\u2013125% of nameplate FLA</b> (depending on service factor / temp rise).",ref:"430.32"},
{id:"m4",cat:"Motors",q:"Motor branch-circuit short-circuit/ground-fault protection (inverse-time breaker) is sized up to about\u2026",opts:["250% of FLC","125% of FLC","100% of FLC","800% of FLC"],correct:0,why:"An inverse-time breaker may be set up to ~<b>250% of FLC</b> by default to allow starting current.",ref:"430.52"},
{id:"m5",cat:"Motors",q:"A feeder serving several motors is sized at\u2026",opts:["125% of the largest motor FLC + sum of the rest","100% of all FLCs","125% of all FLCs","sum of nameplate FLAs"],correct:0,why:"<b>125% of the largest</b> motor's FLC plus the FLCs of the others.",ref:"430.24"},
{id:"m6",cat:"Motors",q:"A motor's starting (locked-rotor) current is roughly\u2026",opts:["6\u00D7 its full-load current","equal to FLC","half of FLC","100\u00D7 FLC"],correct:0,why:"Inrush is commonly about <b>6\u00D7 FLC</b>, which is why SC/GF protection is set well above FLC.",ref:"Motor Starting"},
{id:"m7",cat:"Motors",q:"A motor disconnecting means must generally be located\u2026",opts:["within sight of the motor","at the service only","anywhere in the building","outdoors only"],correct:0,why:"The disconnect must be <b>within sight</b> (and within 50 ft) of the motor and driven machinery.",ref:"430.102(B)"},
/* 3-Phase & Transformers */
{id:"p1",cat:"3-Phase & Transformers",q:"In a wye system, line voltage = phase voltage \u00D7\u2026",opts:["1.732 (\u221A3)","2","3","1.414"],correct:0,why:"Line-to-line = phase \u00D7 \u221A3 (120 V phase \u2192 208 V line).",ref:"3-Phase"},
{id:"p2",cat:"3-Phase & Transformers",q:"A 10 kVA single-phase transformer, 240 V secondary, full-load secondary current \u2248",opts:["41.7 A","24 A","100 A","10 A"],correct:0,why:"<b>I = VA \u00F7 V</b> = 10,000 \u00F7 240 \u2248 41.7 A.",ref:"Transformers"},
{id:"p3",cat:"3-Phase & Transformers",q:"A 4:1 turns ratio with 480 V primary gives a secondary of\u2026",opts:["120 V","1,920 V","476 V","240 V"],correct:0,why:"Steps down by the ratio: 480 \u00F7 4 = <b>120 V</b>.",ref:"Transformers"},
{id:"p4",cat:"3-Phase & Transformers",q:"Which statement about a wye system is true?",opts:["It provides a neutral and line = \u221A3 \u00D7 phase voltage","Line current = \u221A3 \u00D7 phase current","It has no neutral","Line voltage = phase voltage"],correct:0,why:"Wye gives a <b>neutral</b>; line-to-line voltage is \u221A3 \u00D7 the phase (line-to-neutral) voltage.",ref:"3-Phase"},
{id:"p5",cat:"3-Phase & Transformers",q:"In a delta system, line current = phase current \u00D7\u2026",opts:["1.732 (\u221A3)","1","2","0.5"],correct:0,why:"In delta, <b>line current = \u221A3 \u00D7 phase current</b>; line voltage = phase voltage.",ref:"3-Phase"},
{id:"p6",cat:"3-Phase & Transformers",q:"Three-phase power is calculated as\u2026",opts:["\u221A3 \u00D7 V_line \u00D7 I_line \u00D7 pf","V \u00D7 I","2 \u00D7 V \u00D7 I","V\u00B2 \u00F7 R only"],correct:0,why:"<b>P = \u221A3 \u00D7 V_L \u00D7 I_L \u00D7 power factor</b> for a balanced three-phase load.",ref:"3-Phase Power"},
{id:"p7",cat:"3-Phase & Transformers",q:"On a 240/120 V high-leg delta, the high (stinger) leg measures ~208 V to neutral and must be identified\u2026",opts:["orange","blue","green","white"],correct:0,why:"The high leg is marked <b>orange</b> (or otherwise durably identified).",ref:"110.15"},
{id:"p8",cat:"3-Phase & Transformers",q:"Single-phase transformer kVA equals\u2026",opts:["V \u00D7 A \u00F7 1,000","V \u00F7 A","V \u00D7 A \u00D7 1,000","\u221A3 \u00D7 V \u00D7 A"],correct:0,why:"kVA = volts \u00D7 amps \u00F7 1,000 for single-phase.",ref:"Transformers"},
{id:"p9",cat:"3-Phase & Transformers",q:"In a step-down transformer, the secondary (lower-voltage) side has\u2026",opts:["higher current than the primary","lower current","the same current","no current"],correct:0,why:"Power in \u2248 power out, so lower voltage means <b>higher current</b> on the secondary.",ref:"Transformers"},
/* Definitions */
{id:"d1",cat:"Definitions",q:"'Ampacity' is best defined as\u2026",opts:["current a conductor can carry continuously without exceeding its temp rating","the max voltage of a conductor","resistance per foot","the breaker size"],correct:0,why:"Continuous current capacity under conditions of use, limited by <b>temperature rating</b>.",ref:"Article 100"},
{id:"d2",cat:"Definitions",q:"A 'feeder' is the conductors\u2026",opts:["between the service and the final branch-circuit OCPD","after the last breaker to the outlet","from utility to meter","inside a luminaire"],correct:0,why:"Feeders run between the source/service and the <b>final branch-circuit OCPD</b>.",ref:"Article 100"},
{id:"d3",cat:"Definitions",q:"A 'branch circuit' is the conductors\u2026",opts:["between the final OCPD and the outlet(s)","from the utility transformer","between two services","inside the meter base"],correct:0,why:"A branch circuit runs from the <b>final overcurrent device to the outlets</b> it serves.",ref:"Article 100"},
{id:"d4",cat:"Definitions",q:"An 'outlet' is a point on the wiring system where\u2026",opts:["current is taken to supply utilization equipment","wires are spliced only","the meter connects","conduit terminates"],correct:0,why:"An outlet is where <b>current is taken to supply utilization equipment</b> (not just a receptacle).",ref:"Article 100"},
{id:"d5",cat:"Definitions",q:"A 'device' is a unit that\u2026",opts:["carries or controls electricity but doesn't utilize it","consumes power as heat or light","stores energy","steps voltage up"],correct:0,why:"A device (switch, receptacle) <b>carries or controls</b> energy as its principal function rather than using it.",ref:"Article 100"},
{id:"d6",cat:"Definitions",q:"The difference between 'listed' and 'labeled' is that labeled equipment\u2026",opts:["bears a mark of a recognized testing organization","is merely advertised","is used equipment","is field-built"],correct:0,why:"<b>Listed</b> = published in a qualified lab's list; <b>labeled</b> = carries that lab's mark/label on the product.",ref:"Article 100"},
{id:"d7",cat:"Definitions",q:"A 'qualified person' is one who\u2026",opts:["has the skills/knowledge and training to recognize and avoid the hazards","holds any trade card","is over 18","works for a utility"],correct:0,why:"Defined by <b>skills, knowledge, and hazard-avoidance training</b> related to the equipment.",ref:"Article 100"},
{id:"d8",cat:"Definitions",q:"A 'dwelling unit' must include permanent provisions for\u2026",opts:["living, sleeping, cooking, and sanitation","parking and storage","cooking only","sleeping only"],correct:0,why:"All four: <b>living, sleeping, cooking, and sanitation</b>.",ref:"Article 100"},
{id:"d9",cat:"Definitions",q:"The 'service' consists of the conductors and equipment that\u2026",opts:["connect the serving utility to the premises wiring","feed a single motor","make up a branch circuit","bond the rod"],correct:0,why:"The service connects the <b>utility supply to the premises wiring system</b>.",ref:"Article 100"},
{id:"d10",cat:"Definitions",q:"'Accessible' (as applied to wiring methods) means capable of being\u2026",opts:["removed or exposed without damaging the building structure","reached only with a ladder","seen from the street","locked behind a panel"],correct:0,why:"Able to be <b>removed/exposed without damaging the building finish or structure</b>.",ref:"Article 100"},
{id:"cc1",cat:"Code Calculations",eds:["2017","2020","2023"],q:"A 2,000 ft² dwelling (NEC ≤2023) — general lighting load before demand factors?",opts:["6,000 VA","2,000 VA","666 VA","9,000 VA"],correct:0,why:"<b>What:</b> general lighting load. <b>How:</b> area × 3 VA/ft² = 2,000 × 3 = 6,000 VA. <b>Why:</b> the baseline before demand factors (3 VA/ft² applies through the 2023 NEC).",ref:"220.12"},
{id:"cc1b",cat:"Code Calculations",eds:["2026"],q:"A 2,000 ft² dwelling (2026 NEC) — general lighting load before demand factors?",opts:["4,000 VA","6,000 VA","2,000 VA","9,000 VA"],correct:0,why:"<b>What:</b> 2026 general lighting. <b>How:</b> area × 2 VA/ft² = 2,000 × 2 = 4,000 VA. <b>Why:</b> the 2026 NEC reduced dwelling lighting from 3 to 2 VA/ft² — the same house calculates lower than under ≤2023.",ref:"Article 120 (2026)"},
{id:"cc2",cat:"Code Calculations",q:"A 40 A continuous load \u2014 minimum conductor ampacity?",opts:["50 A","40 A","32 A","60 A"],correct:0,why:"<b>What:</b> continuous-load sizing. <b>How:</b> 40 \u00D7 1.25 = 50 A. <b>Why:</b> the 125% factor keeps the conductor cool under hours of steady load.",ref:"210.19(A)"},
{id:"cc3",cat:"Code Calculations",q:"12 AWG copper (6,530 CM), 120 V, single-phase, 16 A, 100 ft one-way. Approx. voltage drop?",opts:["~6.3 V (over 3%)","~1.6 V","~3.2 V","~12.6 V"],correct:0,why:"<b>What:</b> single-phase Vd. <b>How:</b> (2 \u00D7 12.9 \u00D7 16 \u00D7 100) \u00F7 6,530 \u2248 6.3 V \u2248 5.3%. <b>Why:</b> it exceeds the 3% recommendation \u2014 up-size the conductor.",ref:"Voltage Drop"},
{id:"cc4",cat:"Code Calculations",q:"A motor with a table FLC of 28 A \u2014 minimum branch-circuit conductor ampacity?",opts:["35 A","28 A","22 A","70 A"],correct:0,why:"<b>What:</b> motor conductor sizing. <b>How:</b> 28 \u00D7 1.25 = 35 A, using <b>table FLC</b> (not nameplate). <b>Why:</b> conductors must carry continuous motor current with margin.",ref:"430.22"},
{id:"cc5",cat:"Code Calculations",q:"Three motors on one feeder \u2014 FLC 28 A, 16 A, 10 A. Minimum feeder conductor ampacity?",opts:["61 A","54 A","68 A","45 A"],correct:0,why:"<b>What:</b> motor feeder sizing. <b>How:</b> 125% of the largest (28 \u00D7 1.25 = 35) + the rest (16 + 10) = 61 A. <b>Why:</b> only the largest motor gets the 125% starting allowance.",ref:"430.24"},
{id:"cc6",cat:"Code Calculations",q:"A box has 3 conductors, one device on a yoke, internal clamps, and EGCs. How many fill \u2018counts\u2019?",opts:["7","5","6","8"],correct:0,why:"<b>What:</b> box-fill counting. <b>How:</b> 3 conductors (3) + device yoke (2) + all EGCs together (1) + all clamps together (1) = 7. <b>Why:</b> each count maps to a volume allowance so the box isn\u2019t overcrowded.",ref:"314.16(B)"},
{id:"cc7",cat:"Code Calculations",q:"Conductors total 0.20 in\u00B2 in a raceway with 0.50 in\u00B2 internal area, 4 conductors. Fill?",opts:["40% \u2014 at the limit","25% \u2014 fine","50% \u2014 over","80% \u2014 over"],correct:0,why:"<b>What:</b> conduit fill. <b>How:</b> 0.20 \u00F7 0.50 = 40%; the limit for 3+ conductors is 40%. <b>Why:</b> fill limits leave room to pull without damaging insulation.",ref:"Ch. 9, Table 1"},
{id:"cc8",cat:"Code Calculations",q:"Six current-carrying conductors share a raceway. Ampacity adjustment factor?",opts:["80%","70%","50%","100%"],correct:0,why:"<b>What:</b> bundling adjustment. <b>How:</b> 4\u20136 current-carrying conductors \u2192 80%. <b>Why:</b> bundled conductors trap heat, so allowable ampacity drops.",ref:"310.15(C)(1)"},
{id:"cc9",cat:"Code Calculations",q:"A 240 V load draws 60 A. What resistance does it present?",opts:["4 \u03A9","0.25 \u03A9","14,400 \u03A9","300 \u03A9"],correct:0,why:"<b>What:</b> applied Ohm\u2019s law. <b>How:</b> R = V \u00F7 I = 240 \u00F7 60 = 4 \u03A9. <b>Why:</b> ties theory to a real service-level load.",ref:"Ohm\u2019s Law"},
{id:"ce1",cat:"Code & Editions",q:"How often is the National Electrical Code revised?",opts:["Every 3 years","Every year","Every 5 years","Every 10 years"],correct:0,why:"<b>What:</b> the NEC cycle. <b>How:</b> NFPA publishes on a 3-year cycle \u2014 2017, 2020, 2023, 2026. <b>Why:</b> your exam uses whichever edition your state has adopted.",ref:"NEC Cycle"},
{id:"ce2",cat:"Code & Editions",q:"As of 2026, which is the most recent published NEC edition?",opts:["2026","2023","2020","2029"],correct:0,why:"<b>What:</b> the current edition. <b>How:</b> the 2026 NEC was issued in late 2025. <b>Why:</b> \u2018published\u2019 is not \u2018adopted\u2019 \u2014 many states still enforce 2020 or 2023. Confirm your AHJ.",ref:"2026 NEC\u00AE"},
{id:"ce3",cat:"Code & Editions",q:"In the 2026 NEC, branch-circuit/feeder/service load calculations moved from Article 220 to\u2026",opts:["Article 120","Article 230","Article 215","they stayed in 220"],correct:0,why:"<b>What:</b> the 2026 reorganization. <b>How:</b> load calcs moved into Chapter 1 as Article 120. <b>Why:</b> a citation of \u2018220\u2019 is correct through 2023 but wrong for 2026 \u2014 exactly why edition matters.",ref:"120 (2026) / 220 (\u22642023)"},
{id:"ce4",cat:"Code & Editions",q:"In the 2026 NEC, outdoor dwelling outlets rated ___ now require GFCI protection (210.8(F)).",opts:["60 A or less","over 100 A","only 15 A","none of them"],correct:0,why:"<b>What:</b> a 2026 GFCI expansion. <b>How:</b> 210.8(F) now requires GFCI protection on outdoor dwelling outlets rated 60 A or less; an exception permits a listed Class C SPGFCI to protect HVAC equipment. <b>Why:</b> earlier editions covered fewer outdoor outlets — confirm against your adopted edition.",ref:"210.8(F) (2026)"},
{id:"ce5",cat:"Code & Editions",q:"Whether the 2026 NEC actually applies to your job is decided by\u2026",opts:["your state/local jurisdiction (AHJ)","NFPA directly","the manufacturer","federal law"],correct:0,why:"<b>What:</b> adoption vs publication. <b>How:</b> NFPA publishes; states and municipalities adopt on their own timelines, sometimes with amendments. <b>Why:</b> always study the edition your AHJ enforces.",ref:"Adoption"},
{id:"ce6",cat:"Code & Editions",q:"In the 2026 NEC, Energy Management Systems (formerly Article 750) were relocated to…",opts:["Article 130","Article 750 (unchanged)","Article 220","Article 90"],correct:0,why:"<b>What:</b> a 2026 relocation. <b>How:</b> Article 750 (Energy Management Systems) was modified and moved into Chapter 1 as new Article 130 — alongside load calculations moving to Article 120. <b>Why:</b> Chapter 1 now groups foundational, broadly-applied rules.",ref:"Article 130 (2026) / 750 (≤2023)"},
{id:"cu1",cat:"Code & Editions",eds:["2020","2023","2026"],q:"Beginning with the 2020 NEC, services supplying dwelling units must include a…",opts:["surge-protective device (SPD)","second main breaker","GFCI main","manual transfer switch"],correct:0,why:"<b>What:</b> a 2020 addition. <b>How:</b> 230.67 requires a surge-protective device on services to dwelling units. <b>Why:</b> it was not required under the 2017 NEC — a clear, testable edition difference.",ref:"230.67 (2020+)"},
{id:"cu2",cat:"Code & Editions",eds:["2020","2023","2026"],q:"The 2020 NEC introduced a required outdoor emergency disconnect for…",opts:["one- and two-family dwellings","all commercial buildings","detached garages only","RV parks"],correct:0,why:"<b>What:</b> a 2020 addition. <b>How:</b> 230.85 requires a readily accessible outdoor emergency disconnect at one- and two-family dwellings (refined further in 2023). <b>Why:</b> absent from the 2017 NEC.",ref:"230.85 (2020+)"}
];
const LESSONS=[
{id:"ed",cat:"Code & Editions",t:"NEC Editions: Why the Year Matters",mins:4,body:`<p>The NEC is revised every three years — 2017, 2020, 2023, 2026. NFPA <b>publishes</b> an edition, but your state or city <b>adopts</b> it on its own schedule — sometimes years later, sometimes with local amendments.</p><p>So two things are always true: the rules change between editions, and the edition you must follow is whatever your <b>AHJ</b> has adopted — not necessarily the newest one.</p><p>The 2026 cycle is unusually large. Load calculations moved from <b>Article 220 to Article 120</b>, Energy Management moved from <b>750 to 130</b>, and dwelling general lighting dropped from <b>3 to 2 VA/ft²</b>. A citation that was right in 2023 can be wrong in 2026.</p><p>Set your edition in Settings — Knowatt filters practice so the answers match the code you are tested on.</p>`,keys:["Three-year cycle: 2017 / 2020 / 2023 / 2026.","Published ≠ adopted — your AHJ decides.","2026: 220→120, 750→130, 3→2 VA/ft².","Always study your adopted edition."],refs:["90.2","Adoption"]},
{id:"gb",cat:"Grounding & Bonding",t:"Grounding vs. Bonding",mins:4,body:`<p><b>Grounding</b> connects to the earth (rod, water pipe, Ufer). <b>Bonding</b> connects metal parts to each other so they're electrically continuous.</p><p>The job that saves lives is bonding. When a hot faults to a metal enclosure, the <b>equipment grounding conductor (EGC)</b> and bonding carry that fault current back to the source so the breaker trips \u2014 not the dirt.</p><p>Earth impedance is too high to clear a fault, so grounding to earth doesn't trip breakers. It references the system to a stable potential and dissipates surges.</p>`,keys:["Bonding ties metal parts for a fault path.","Grounding ties the system to earth for stability/surges.","The EGC \u2014 not earth \u2014 clears ground faults.","#1 conceptual exam mistake."],refs:["250.4(A)","250.90"]},
{id:"r125",cat:"Loads & OCPD",t:"The 125% Continuous-Load Rule",mins:3,body:`<p>Loads running <b>3 hours or more</b> are continuous. Size conductors and the OCPD at 100% noncontinuous <b>plus 125% continuous</b> \u2014 the extra 25% is breathing room against heat.</p><p>Example: 16 A continuous \u2192 16 \u00D7 1.25 = 20 A.</p><p>A popular app shipped this as 150%. It's <b>125%</b>. The job-site "80% rule" is the same idea inverted.</p>`,keys:["Continuous = 3 hours or more.","100% noncontinuous + 125% continuous.","125%, never 150%.","80% rule = inverted."],refs:["210.19(A)","210.20(A)"]},
{id:"amp",cat:"Conductors",t:"Ampacity & Why We Derate",mins:5,body:`<p>Ampacity is continuous current without cooking insulation. It moves with: <b>insulation temp rating</b> (60/75/90 \u00B0C), <b>ambient temperature</b>, and <b>bundling</b> (>3 CCC = adjustment factors).</p><p>The catch: <b>terminations</b>. Lugs/breakers limit you to 60 \u00B0C (\u2264100 A) or 75 \u00B0C unless marked otherwise. Run the math at 90 \u00B0C, but <b>the lowest limit wins</b>.</p>`,keys:["Ampacity = continuous current vs insulation temp.","Adjust for ambient + bundling.","Terminations cap the result (110.14(C)).","Lowest limit governs."],refs:["310.15(C)","110.14(C)"]},
{id:"vd",cat:"Voltage Drop",t:"Voltage Drop: Recommended, Not Required",mins:3,body:`<p>The NEC doesn't mandate voltage drop for most branch circuits. The 3%/5% figures are <b>informational notes</b>.</p><p>Why care? Drop wastes energy and hurts motors, electronics, and lighting. Up-size conductors on long runs.</p><p>Single-phase: <b>Vd = (2 \u00D7 K \u00D7 I \u00D7 L) \u00F7 CM</b>, K \u2248 12.9 Cu / 21.2 Al. The 2 is out-and-back; three-phase uses 1.732.</p>`,keys:["3%/5% are recommendations.","Drop hurts motors, electronics, lighting.","Vd \u221D current \u00D7 length.","Up-size on long runs."],refs:["210.19(A) IN","215.2(A) IN"]},
{id:"oc",cat:"Loads & OCPD",t:"Overload vs. Short Circuit vs. Ground Fault",mins:4,body:`<ul><li><b>Overload</b> \u2014 modest, persistent overcurrent; the breaker's <b>thermal</b> element trips with a delay.</li><li><b>Short circuit</b> \u2014 huge current; the <b>magnetic</b> element trips instantly.</li><li><b>Ground fault</b> \u2014 unintended path to ground; mA-level people-protection needs a <b>GFCI</b>.</li></ul><p>That's why breakers are <b>thermal-magnetic</b>.</p>`,keys:["Overload: thermal, delayed.","Short circuit: magnetic, instant.","Ground fault: mA needs GFCI.","Breaker = thermal-magnetic."],refs:["240.1","Article 100"]},
{id:"ga",cat:"GFCI / AFCI",t:"GFCI vs. AFCI",mins:3,body:`<p><b>GFCI</b> protects <b>people</b>: it senses ~4\u20136 mA of leakage and trips in milliseconds. Wet locations.</p><p><b>AFCI</b> protects <b>property</b> from fire: it recognizes dangerous arcing a normal breaker never sees. Living/sleeping areas.</p><p>One-liner: GFCI saves people; AFCI saves buildings. Dual-function does both.</p>`,keys:["GFCI \u2192 people (~4\u20136 mA).","AFCI \u2192 fire/arc faults.","GFCI wet areas; AFCI living areas.","Dual-function = both."],refs:["210.8","210.12"]},
{id:"oh",cat:"Theory",t:"Ohm's Law & the Power Wheel",mins:4,body:`<p>Everything rests on <b>V = I \u00D7 R</b>. Add power: <b>P = V \u00D7 I = I\u00B2R = V\u00B2/R</b>. Any two of V/I/R/P find the rest.</p><ul><li>Voltage is pressure, current is flow, resistance is restriction.</li><li>Conductor heat is <b>I\u00B2R</b> \u2014 scales with the <b>square</b> of current. Halve current, quarter the heat.</li></ul>`,keys:["V = I \u00D7 R.","P = VI = I\u00B2R = V\u00B2/R.","Any two find the rest.","Heat = I\u00B2R."],refs:["Ohm's Law","Power"]},
{id:"std",cat:"Loads & OCPD",t:"Standard Sizes & the Next-Size-Up Rule",mins:3,body:`<p>Standard OCPD ratings are fixed: 15, 20, 25, 30, 35, 40, 45, 50, 60, 70, 80, 90, 100\u2026 Notice there's <b>no 65 A</b> \u2014 after 60 comes 70.</p><p>When a conductor's ampacity lands between standard sizes, <b>240.4(B)</b> lets you go up to the next standard device (\u2264800 A) under its conditions. Above 800 A you must round down.</p>`,keys:["Memorize the standard ladder.","No 65 A \u2014 60 then 70.","\u2264800 A: round up allowed.","800 A: round down."],refs:["240.6(A)","240.4(B)"]},
{id:"req",cat:"GFCI / AFCI",t:"Where GFCI & AFCI Are Required",mins:4,body:`<p><b>GFCI</b> (people): bathrooms, kitchens (countertop), garages, outdoors, crawl spaces, unfinished basements, laundry, and near sinks.</p><p><b>AFCI</b> (fire): most 120 V, 15/20 A branch circuits serving dwelling living and sleeping areas \u2014 bedrooms, living rooms, hallways, and more.</p><p>Dual-function (DFCI) devices cover both where each is required.</p>`,keys:["GFCI \u2192 wet/grounded areas.","AFCI \u2192 living/sleeping areas.","Kitchen counters need GFCI.","DFCI covers both."],refs:["210.8","210.12"]},
{id:"mot",cat:"Motors",t:"Motor Protection in Layers",mins:4,body:`<p>Motors get protected in two layers because starting current (~6\u00D7 FLC) would nuisance-trip ordinary protection.</p><ul><li><b>Overload</b> (running): 115\u2013125% of <b>nameplate FLA</b> \u2014 protects the windings over time.</li><li><b>Short-circuit/ground-fault</b> (branch): set high (an inverse-time breaker up to ~250% of <b>table FLC</b>) to ride through inrush but still clear faults.</li></ul><p>Conductors size from <b>table FLC</b> at 125%; overloads from nameplate.</p>`,keys:["Two layers: overload + SC/GF.","Overload 115\u2013125% nameplate.","SC/GF up to ~250% FLC.","Conductors 125% of table FLC."],refs:["430.32","430.52","430.22"]},
{id:"three",cat:"3-Phase & Transformers",t:"Three-Phase: Wye vs. Delta",mins:4,body:`<p><b>Wye</b> has a neutral. Line-to-line voltage = phase \u00D7 \u221A3 (120 V \u2192 208 V); line current = phase current.</p><p><b>Delta</b> has no neutral (except high-leg). Line voltage = phase voltage; line current = phase \u00D7 \u221A3.</p><p>Three-phase power: <b>P = \u221A3 \u00D7 V_L \u00D7 I_L \u00D7 pf</b>. The \u221A3 (1.732) is everywhere in three-phase math \u2014 know it cold.</p>`,keys:["Wye: V_line = \u221A3 \u00D7 phase, has neutral.","Delta: I_line = \u221A3 \u00D7 phase.","P = \u221A3 \u00D7 V_L \u00D7 I_L \u00D7 pf.","\u221A3 \u2248 1.732."],refs:["3-Phase"]},
{id:"fill",cat:"Raceway & Boxes",t:"Conduit & Box Fill",mins:4,body:`<p><b>Conduit fill</b> limits crowding: 1 conductor = 53%, 2 = 31%, 3 or more = 40% of the raceway's internal area.</p><p><b>Box fill</b> counts conductor volumes: each conductor entering = 1; all EGCs together = 1; all clamps together = 1; each device yoke = 2 (of the largest conductor on it). Sum, then compare to the box's volume.</p>`,keys:["Fill: 53% / 31% / 40%.","Each conductor = 1 volume.","EGCs together = 1; clamps = 1.","Device yoke = 2 volumes."],refs:["Ch. 9 Table 1","314.16(B)"]}
];
const ARTICLES=[
{id:"a100",num:"Article 100",sub:"General \u00B7 Definitions",cats:["Definitions","Theory"]},
{id:"a210",num:"Article 210",sub:"Branch Circuits",cats:["Loads & OCPD","GFCI / AFCI"]},
{id:"a220",num:"Article 220",sub:"Load Calculations",cats:["Loads & OCPD"]},
{id:"a240",num:"Article 240",sub:"Overcurrent Protection",cats:["Conductors","Loads & OCPD"]},
{id:"a250",num:"Article 250",sub:"Grounding & Bonding",cats:["Grounding & Bonding"]},
{id:"a310",num:"Article 310",sub:"Conductors & Ampacity",cats:["Conductors","Voltage Drop"]},
{id:"a314",num:"Article 314",sub:"Boxes & Conduit Bodies",cats:["Raceway & Boxes"]},
{id:"a430",num:"Article 430",sub:"Motors & Controllers",cats:["Motors","3-Phase & Transformers"]}
];
const GLOSSARY=[
{t:"Ampacity",d:"The current a conductor can carry continuously, under its conditions of use, without exceeding its temperature rating."},
{t:"Bonding",d:"Connecting metal parts together to make them electrically continuous so they can safely carry fault current."},
{t:"Grounding (Earthing)",d:"Connecting equipment or a system to the earth, primarily to stabilize voltage and dissipate surges."},
{t:"Equipment Grounding Conductor (EGC)",d:"The conductor that provides a low-impedance fault path back to the source so the overcurrent device opens."},
{t:"Grounded Conductor",d:"The neutral \u2014 a circuit conductor that is intentionally grounded (usually white or gray)."},
{t:"Grounding Electrode Conductor (GEC)",d:"The conductor connecting the grounded system and/or equipment to the grounding electrode (rod, water pipe, Ufer)."},
{t:"Branch Circuit",d:"The conductors between the final overcurrent device and the outlet(s) it supplies."},
{t:"Feeder",d:"The conductors between the service (or other power source) and the final branch-circuit overcurrent device."},
{t:"Service",d:"The conductors and equipment connecting the serving utility to the premises wiring system."},
{t:"Outlet",d:"A point on the wiring system where current is taken to supply utilization equipment."},
{t:"Device",d:"A unit of the system that carries or controls electricity but does not consume it as its principal function (e.g., a switch)."},
{t:"Continuous Load",d:"A load where the maximum current is expected to continue for 3 hours or more."},
{t:"Overcurrent",d:"Current above the rated value of equipment or a conductor \u2014 from overload, short circuit, or ground fault."},
{t:"Listed",d:"Equipment included in a list published by a recognized testing organization."},
{t:"Labeled",d:"Equipment bearing the mark or label of a recognized testing organization."},
{t:"Qualified Person",d:"One with the skills, knowledge, and training to recognize and avoid the hazards involved."},
{t:"Power Factor",d:"The ratio of real power (W) to apparent power (VA); 1.0 means all supplied power does useful work."},
{t:"GFCI",d:"Ground-Fault Circuit Interrupter \u2014 trips on ~4\u20136 mA of leakage to protect people from shock."},
{t:"AFCI",d:"Arc-Fault Circuit Interrupter \u2014 detects dangerous arcing to reduce the risk of electrical fires."}
];
const CM={"14 AWG":4110,"12 AWG":6530,"10 AWG":10380,"8 AWG":16510,"6 AWG":26240,"4 AWG":41740,"3 AWG":52620,"2 AWG":66360,"1 AWG":83690,"1/0":105600,"2/0":133100,"3/0":167800,"4/0":211600,"250 kcmil":250000,"350 kcmil":350000,"500 kcmil":500000};
const STDOCPD=[15,20,25,30,35,40,45,50,60,70,80,90,100,110,125,150,175,200,225,250,300,350,400];
const EDITIONS=["2017 NEC\u00AE","2020 NEC\u00AE","2023 NEC\u00AE","2026 NEC\u00AE"];
const APT_MATH=[
{id:"am1",sec:"Math",q:"Solve for x:  3x + 7 = 22",opts:["5","6","8","15"],correct:0,why:"Subtract 7 from both sides: 3x = 15. Divide by 3: x = 5."},
{id:"am2",sec:"Math",q:"Solve for x:  2(x − 4) = 10",opts:["9","7","5","3"],correct:0,why:"Divide both sides by 2: x − 4 = 5, so x = 9. (Or distribute: 2x − 8 = 10 → 2x = 18 → x = 9.)"},
{id:"am3",sec:"Math",q:"2/3 + 1/4 = ?",opts:["11/12","3/7","5/6","2/12"],correct:0,why:"Use a common denominator of 12: 8/12 + 3/12 = 11/12."},
{id:"am4",sec:"Math",q:"3/4 ÷ 1/2 = ?",opts:["1.5","0.375","0.5","2"],correct:0,why:"Dividing by a fraction means multiply by its reciprocal: 3/4 × 2 = 6/4 = 1.5."},
{id:"am5",sec:"Math",q:"What is 15% of 80?",opts:["12","15","8","120"],correct:0,why:"0.15 × 80 = 12."},
{id:"am6",sec:"Math",q:"2⁵ = ?",opts:["32","10","16","25"],correct:0,why:"2 × 2 × 2 × 2 × 2 = 32."},
{id:"am7",sec:"Math",q:"Evaluate:  6 + 2 × 3²",opts:["24","72","36","12"],correct:0,why:"Order of operations: 3² = 9, then 2 × 9 = 18, then 6 + 18 = 24."},
{id:"am8",sec:"Math",q:"Find the next number:  2, 6, 18, 54, ?",opts:["162","108","72","216"],correct:0,why:"Each term is multiplied by 3: 54 × 3 = 162."},
{id:"am9",sec:"Math",q:"Find the next number:  3, 7, 11, 15, ?",opts:["19","18","20","23"],correct:0,why:"Add 4 each step: 15 + 4 = 19."},
{id:"am10",sec:"Math",q:"If f(x) = 2x + 3, what is f(5)?",opts:["13","10","16","7"],correct:0,why:"Substitute x = 5: 2(5) + 3 = 13."},
{id:"am11",sec:"Math",q:"Solve for x:  x / 5 = 9",opts:["45","1.8","14","4"],correct:0,why:"Multiply both sides by 5: x = 45."},
{id:"am12",sec:"Math",q:"−3 × −4 = ?",opts:["12","−12","−7","7"],correct:0,why:"A negative times a negative is positive: 12."},
{id:"am13",sec:"Math",q:"A crew pulls 250 ft of wire in 5 hours. At that rate, how long to pull 400 ft?",opts:["8 hours","6.4 hours","10 hours","7 hours"],correct:0,why:"Rate = 250 ÷ 5 = 50 ft/hr. 400 ÷ 50 = 8 hours."},
{id:"am14",sec:"Math",q:"Simplify:  (4x²)(3x³)",opts:["12x⁵","7x⁵","12x⁶","7x⁶"],correct:0,why:"Multiply the coefficients (4 × 3 = 12); add the exponents (2 + 3 = 5): 12x⁵."},
{id:"am15",sec:"Math",q:"Solve the inequality:  2x > 10",opts:["x > 5","x < 5","x > 20","x > 8"],correct:0,why:"Divide both sides by 2: x > 5."},
{id:"am16",sec:"Math",q:"What is the average (mean) of 4, 8, 10, and 14?",opts:["9","10","8","12"],correct:0,why:"Sum = 36; 36 ÷ 4 = 9."},
{id:"am17",sec:"Math",q:"A value rises from 40 to 50. What is the percent increase?",opts:["25%","20%","10%","2.5%"],correct:0,why:"Increase = 10. Divide by the original: 10 ÷ 40 = 0.25 = 25%."},
{id:"am18",sec:"Math",q:"Find the next letter:  A, C, E, G, ?",opts:["I","H","J","K"],correct:0,why:"Skip one letter each time: A, [B], C, [D], E, [F], G, [H], I."}
];
const PT1="An electrical apprenticeship blends two kinds of learning. On the job, an apprentice works beside experienced journeymen — bending conduit, pulling wire, and troubleshooting real problems under supervision. In the classroom, that same apprentice studies theory, code, and safety: the reasoning behind the work. Neither half is enough alone. A worker who can recite the code but has never pulled a feeder will struggle in the field; one who is skilled with their hands but does not understand why a circuit is protected at a certain rating can create hazards. The model deliberately ties the two together over several years, so knowledge and skill grow at the same pace. By the time the apprentice becomes a journeyman, the two have become one.";
const PT2="Technical standards are not written once and left alone. They are revised on regular cycles as technology, materials, and field experience change. A rule that made sense when most homes used incandescent lighting may be too conservative once efficient LED fixtures become common. Committees review proposals, weigh evidence, and publish an updated edition. Importantly, publishing a new edition does not make it law everywhere at once. Each jurisdiction decides when — or whether — to adopt it, sometimes with local changes. As a result, two cities in the same state can enforce different editions of the same standard in the same year. Professionals must therefore know not only the rules, but which version applies where they work.";
const PT3="On any work site, the temptation to rush is constant. A job finished quickly looks productive, and a fast worker earns praise. But speed without care has hidden costs. A connection made in haste may pass a glance yet fail months later, forcing a return trip, new materials, and lost trust. Mistakes caught early are cheap; the same mistake found after the walls are closed can cost many times more to fix. Experienced workers learn to separate useful speed — efficient movement and good planning — from reckless speed that skips steps. The goal is not to work slowly, but to work in a way that does not have to be redone.";
const APT_READ=[
{id:"r1",sec:"Reading",passageTitle:"Learning the Trade",passage:PT1,q:"Which best states the main idea of the passage?",opts:["Apprenticeship works because it combines hands-on work with classroom theory","Classroom study matters more than fieldwork","Most apprentices already know the trade before they start","Journeymen no longer need to study code"],correct:0,why:"The central point is that the two kinds of learning are tied together, and neither is enough alone."},
{id:"r2",sec:"Reading",passageTitle:"Learning the Trade",passage:PT1,q:"According to the passage, a worker who knows the code but has no field experience will likely…",opts:["struggle in the field","become a journeyman faster","never need supervision","avoid all hazards"],correct:0,why:"The passage states such a worker 'will struggle in the field.'"},
{id:"r3",sec:"Reading",passageTitle:"Learning the Trade",passage:PT1,q:"The passage suggests that the two kinds of learning are…",opts:["more effective together than separately","equally useless on their own","taught in a single day","only for journeymen"],correct:0,why:"It says neither half is enough alone and they grow at the same pace — implying together they work best."},
{id:"r4",sec:"Reading",passageTitle:"Learning the Trade",passage:PT1,q:"As used in the passage, 'the reasoning behind the work' most nearly means…",opts:["understanding why the work is done a certain way","the speed of the work","the cost of materials","the name of each tool"],correct:0,why:"It is paired with 'theory, code, and safety' — the why behind the task."},
{id:"r5",sec:"Reading",passageTitle:"Why Standards Change",passage:PT2,q:"What is the main idea of the passage?",opts:["Standards are revised regularly, but adoption varies by place","Standards never change once published","LED lighting made all old rules unsafe","Only the federal government adopts standards"],correct:0,why:"The passage centers on regular revision plus jurisdiction-by-jurisdiction adoption."},
{id:"r6",sec:"Reading",passageTitle:"Why Standards Change",passage:PT2,q:"According to the passage, publishing a new edition…",opts:["does not automatically make it law everywhere","instantly replaces all older editions","is decided by manufacturers","happens once a decade"],correct:0,why:"It explicitly says publishing does not make it law everywhere at once."},
{id:"r7",sec:"Reading",passageTitle:"Why Standards Change",passage:PT2,q:"The passage implies that two cities in the same state might…",opts:["enforce different editions in the same year","never use the same standard","ignore the standard entirely","write their own physics"],correct:0,why:"Adoption timing varies, so different editions can apply at the same time — an inference about two cities."},
{id:"r8",sec:"Reading",passageTitle:"Why Standards Change",passage:PT2,q:"As used in the passage, 'conservative' most nearly means…",opts:["stricter, allowing extra margin","political","old-fashioned","inexpensive"],correct:0,why:"A rule being 'too conservative' for efficient lighting means it built in more margin than needed."},
{id:"r9",sec:"Reading",passageTitle:"The Cost of Rushing",passage:PT3,q:"Which best captures the main idea?",opts:["Working carefully is often more valuable than working fast","Fast workers are always the best workers","Mistakes never matter if the job looks done","Planning wastes time on a job site"],correct:0,why:"The passage argues care can outweigh raw speed, because rushed work is often redone."},
{id:"r10",sec:"Reading",passageTitle:"The Cost of Rushing",passage:PT3,q:"According to the passage, a mistake found after the walls are closed…",opts:["costs many times more to fix than one caught early","is impossible to repair","is cheaper to fix","is always someone else's fault"],correct:0,why:"It directly contrasts cheap early mistakes with costly ones found after walls are closed."},
{id:"r11",sec:"Reading",passageTitle:"The Cost of Rushing",passage:PT3,q:"The author would most likely agree that…",opts:["useful speed comes from planning, not skipping steps","all speed is dangerous","praise is the goal of good work","slow work is always better"],correct:0,why:"The author separates 'useful speed' (planning, efficiency) from reckless step-skipping."},
{id:"r12",sec:"Reading",passageTitle:"The Cost of Rushing",passage:PT3,q:"In the passage, 'reckless speed' is contrasted with…",opts:["efficient movement and good planning","slow and lazy work","expensive materials","working overtime"],correct:0,why:"The text contrasts reckless speed with 'efficient movement and good planning.'"}
];
const WORKED=[
{id:"w1",t:"Size a continuous load",scenario:"A 44 A continuous load. Find the minimum conductor ampacity and the overcurrent device (OCPD).",steps:[
 {h:"What are we solving?",d:"A continuous load runs 3 hours or more. Both the conductor and the OCPD must be sized at 125% of that load."},
 {h:"How — apply the 125% factor",d:"44 A × 1.25 = 55 A. That is the minimum required ampacity / device rating."},
 {h:"What — choose the standard device",d:"There is no 55 A standard breaker, so round up to the next standard size: 60 A (standard sizes are listed in 240.6)."},
 {h:"Why it matters",d:"The 25% cushion keeps the conductor from overheating under hours of steady current. Note: the 2026 NEC removed the 125% step from load-calculation methodology, but it still applies here — to conductor and equipment sizing."}],
 answer:"Conductor ≥ 55 A; OCPD = 60 A.",refs:["210.19","210.20","240.6"]},
{id:"w2",t:"Single-phase voltage drop",scenario:"10 AWG copper (10,380 circular mils), 240 V, 30 A, 150 ft one-way. Find the voltage drop and percentage.",steps:[
 {h:"What — the formula",d:"Single-phase Vd ≈ (2 × K × I × L) ÷ CM, where K ≈ 12.9 for copper, I is current, L is one-way length, CM is the conductor's circular mils."},
 {h:"How — plug in the numbers",d:"(2 × 12.9 × 30 × 150) ÷ 10,380 = 116,100 ÷ 10,380 ≈ 11.2 V."},
 {h:"What — convert to a percentage",d:"11.2 V ÷ 240 V ≈ 4.7%."},
 {h:"Why it matters",d:"That exceeds the NEC's ~3% recommendation for a branch circuit, so you would up-size the conductor or shorten the run."}],
 answer:"≈ 11.2 V drop (≈ 4.7%) — over the 3% guideline.",refs:["Voltage Drop"]},
{id:"w3",t:"Dwelling general lighting — edition-aware",scenario:"A 1,800 ft² dwelling. Find the general lighting load before demand factors — and see how the code edition changes the answer.",steps:[
 {h:"What — the rule",d:"General lighting load = floor area × VA per square foot. The VA value depends on which NEC edition your jurisdiction has adopted."},
 {h:"How — 2017 / 2020 / 2023",d:"1,800 ft² × 3 VA/ft² = 5,400 VA. (Found in Article 220.)"},
 {h:"How — 2026",d:"1,800 ft² × 2 VA/ft² = 3,600 VA. The 2026 NEC reduced dwelling lighting to 2 VA/ft² and moved load calcs to Article 120."},
 {h:"Why it matters",d:"Same house, two different answers. Citing the wrong edition gives the wrong load — which is exactly why Knowatt filters by your edition."}],
 answer:"5,400 VA under ≤2023; 3,600 VA under 2026.",refs:["220.12 (≤2023)","Article 120 (2026)"]},
{id:"w4",t:"Motor feeder sizing",scenario:"Three motors share one feeder, with table full-load currents (FLC) of 34 A, 21 A, and 14 A. Find the minimum feeder conductor ampacity.",steps:[
 {h:"What — the rule",d:"A feeder for several motors = 125% of the largest motor's FLC + the FLC of every other motor. Use the NEC table FLC, not the nameplate value."},
 {h:"How — the largest motor",d:"Largest is 34 A: 34 × 1.25 = 42.5 A."},
 {h:"How — add the rest",d:"Add the other motors at 100%: 21 + 14 = 35 A. Total = 42.5 + 35 = 77.5 A."},
 {h:"Why it matters",d:"Only the largest motor gets the 125% starting allowance; the others are counted at full load. This handles start-up surge without oversizing the whole feeder."}],
 answer:"≥ 77.5 A feeder conductor.",refs:["430.24"]}
];

function citeFor(ref){let r=ref,tag="";if(st.code&&st.code.indexOf("2026")>-1&&ref.indexOf("220.")===0){r="120."+ref.slice(4);tag=" \u00B7 moved in 2026";}return `<span class="ref">${r}${tag}</span>`}
function ord(n){return n+["th","st","nd","rd"][(n%10<4?n%10:0)]}
const LADDER=[
{focus:"Safety, DC theory, hand and power tools, conduit bending, and residential rough-in.",next:"AC theory and conductor/raceway fundamentals."},
{focus:"AC theory, conductors, raceways and boxes, and learning to navigate the NEC.",next:"Motors, controls, and NEC load calculations."},
{focus:"Motors and motor controls, transformers, and core NEC calculations (loads, voltage drop).",next:"Commercial/industrial systems and deeper grounding & bonding."},
{focus:"Commercial and industrial systems, advanced controls, blueprint reading, and grounding/bonding in depth.",next:"Code mastery and journeyman exam prep."},
{focus:"Full code mastery, advanced controls and automation, and journeyman exam preparation.",next:"Sitting for your journeyman license."}];
function ladderPanel(){const lic=/Journeyman|Master/.test(st.level);
 if(lic){const isM=/Master/.test(st.level);
   return `<div class="card" style="margin-top:13px"><div style="font-family:Poppins;font-weight:700;font-size:15px">Your Path \u00B7 ${isM?"Master":"Journeyman"}</div><div style="font-size:13px;color:#cdd7e2;margin-top:8px;line-height:1.5">${isM?"Top of the ladder \u2014 keep sharp on code-edition changes and design-level calculations.":"You\u2019ve completed the apprenticeship. Focus now on full code mastery, calculations, and \u2014 if you\u2019re aiming higher \u2014 Master-level prep."}</div></div>`}
 const y=st.year;
 if(!y)return `<div class="card" style="margin-top:13px"><div style="font-family:Poppins;font-weight:700;font-size:15px">Your Path</div><div style="font-size:13px;color:var(--mut);margin:7px 0 11px">Which apprenticeship year are you in?</div><div class="chiprow">${[1,2,3,4,5].map(n=>`<button class="lvl" data-act="setyear" data-arg="${n}">Yr ${n}</button>`).join("")}</div></div>`;
 const L=LADDER[Math.min(y,5)-1];
 return `<div class="card" style="margin-top:13px"><div style="display:flex;justify-content:space-between;align-items:flex-start"><div style="font-family:Poppins;font-weight:700;font-size:15px">You\u2019re a ${ord(y)}-year apprentice</div><button class="chgbtn" data-act="setyear" data-arg="0">Change</button></div><div style="font-size:13px;color:#cdd7e2;margin-top:9px;line-height:1.5"><b style="color:var(--gold)">Now:</b> ${L.focus}</div><div style="font-size:13px;color:#cdd7e2;margin-top:6px;line-height:1.5"><b style="color:var(--gold)">Next:</b> ${L.next}</div></div>`}

/* ===================== STATE ===================== */
const KEY="knowatt_v3";
let st=load();
function fresh(){return{onboarded:false,name:"",level:"Journeyman Electrician",code:"2023 NEC\u00AE",
  cat:{},qstat:{},bookmarks:[],wrong:[],cor:0,inc:0,mocks:[],tests:0,testCor:0,testInc:0,read:[],days:[],year:null,aptScores:[]}}
function load(){try{const s=localStorage.getItem(KEY);return s?Object.assign(fresh(),JSON.parse(s)):fresh()}catch(e){return fresh()}}
function save(){try{localStorage.setItem(KEY,JSON.stringify(st))}catch(e){}}
function fmt(d){return d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0")+"-"+String(d.getDate()).padStart(2,"0")}
function touchDay(){const t=fmt(new Date());if(!st.days.includes(t)){st.days.push(t);if(st.days.length>400)st.days=st.days.slice(-400)}}
function streak(){const s=new Set(st.days);let n=0,d=new Date();if(!s.has(fmt(d)))d.setDate(d.getDate()-1);while(s.has(fmt(d))){n++;d.setDate(d.getDate()-1)}return n}
const ALLED=["2017","2020","2023","2026"];
function curEd(){return (st.code&&st.code.match(/\d{4}/)||["2023"])[0]}
function qEds(q){return q.eds||ALLED}
function AQ(){const e=curEd();return QUESTIONS.filter(q=>qEds(q).includes(e))}
function mastery(){const t=st.cor+st.inc;return t?Math.round(st.cor/t*100):0}
function masteredCount(){return Object.values(st.qstat).filter(x=>x.cor>0).length}
function catMastery(c){const x=st.cat[c];return x&&x.seen?Math.round(x.cor/x.seen*100):0}
function avg(){return st.mocks.length?Math.round(st.mocks.reduce((a,b)=>a+b,0)/st.mocks.length):0}
function recordAnswer(q,ok){
  const qs=st.qstat[q.id]||{seen:0,cor:0,wrong:0};qs.seen++;ok?qs.cor++:qs.wrong++;st.qstat[q.id]=qs;
  const c=st.cat[q.cat]||{seen:0,cor:0};c.seen++;if(ok)c.cor++;st.cat[q.cat]=c;
  if(ok){st.cor++;st.wrong=st.wrong.filter(id=>id!==q.id)}else{st.inc++;if(!st.wrong.includes(q.id))st.wrong.push(q.id)}
  touchDay();save();}
function toggleBookmark(id){if(st.bookmarks.includes(id))st.bookmarks=st.bookmarks.filter(x=>x!==id);else st.bookmarks.push(id);save()}

/* ===================== APP ===================== */
function MOCKN(){return Math.min(80,AQ().length)}
let app={route:"home",sub:null,sub2:null,quiz:null,studyTab:"topics",studyQ:"",fc:null,tint:null,ob:{level:"Journeyman Electrician"}};
const Vw=()=>document.getElementById("view");
function enter(){document.getElementById("splash").classList.add("hide");if(st.onboarded)go("home");else{app.route="onboard";render()}}
function go(r){stopTimer();app.route=r;app.sub=null;app.quiz=null;app.fc=null;render()}
const FOCUS=()=>app.route==="onboard"||app.quiz||app.fc||["mockintro","lesson","calc","glossary","settings","apt","worked","workeddetail"].includes(app.sub);
function render(){const v=Vw();v.scrollTop=0;
  if(app.route==="onboard")v.innerHTML=vOnboard();
  else if(app.quiz)v.innerHTML=app.quiz.done?vDone():vQuiz();
  else if(app.fc)v.innerHTML=vFlash();
  else if(app.sub==="mockintro")v.innerHTML=vMockIntro();
  else if(app.sub==="lesson")v.innerHTML=vLesson();
  else if(app.sub==="calc")v.innerHTML=vCalc();
  else if(app.sub==="glossary")v.innerHTML=vGlossary();
  else if(app.sub==="settings")v.innerHTML=vSettings();
  else if(app.sub==="apt")v.innerHTML=vApt();
  else if(app.sub==="worked")v.innerHTML=vWorked();
  else if(app.sub==="workeddetail")v.innerHTML=vWorkedDetail();
  else if(app.route==="home")v.innerHTML=vHome();
  else if(app.route==="practice")v.innerHTML=vPractice();
  else if(app.route==="study")v.innerHTML=vStudy();
  else if(app.route==="results")v.innerHTML=vResults();
  else if(app.route==="more")v.innerHTML=vMore();
  const f=v.firstElementChild;if(f)f.classList.add("fade");
  const nav=document.getElementById("nav");nav.classList.toggle("hide",!!FOCUS());if(!FOCUS())renderNav();
  if(app.quiz&&!app.quiz.done)startTimer();}

function I(n){const p={
 home:'<path d="M3 11l9-8 9 8"/><path d="M5 10v10h14V10"/>',practice:'<path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z"/>',
 study:'<path d="M4 5a2 2 0 0 1 2-2h13v16H6a2 2 0 0 0-2 2z"/><path d="M19 19H6"/>',results:'<path d="M5 19V9"/><path d="M10 19V5"/><path d="M15 19v-7"/><path d="M20 19v-4"/>',
 more:'<circle cx="5" cy="12" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="19" cy="12" r="1.6"/>',
 bell:'<path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.7 21a2 2 0 0 1-3.4 0"/>',
 gear:'<circle cx="12" cy="12" r="3"/><path d="M19.4 13a1.7 1.7 0 0 0 .3 1.9l.1.1a2 2 0 1 1-2.8 2.8l-.1-.1a1.7 1.7 0 0 0-2.9 1.2V21a2 2 0 1 1-4 0v-.2A1.7 1.7 0 0 0 6 19.4a1.7 1.7 0 0 0-1.9.3l-.1.1a2 2 0 1 1-2.8-2.8l.1-.1A1.7 1.7 0 0 0 1.5 14H1a2 2 0 1 1 0-4h.2A1.7 1.7 0 0 0 4.6 6a1.7 1.7 0 0 0-.3-1.9l-.1-.1a2 2 0 1 1 2.8-2.8l.1.1A1.7 1.7 0 0 0 10 1.5V1a2 2 0 1 1 4 0v.2A1.7 1.7 0 0 0 18 4.6a1.7 1.7 0 0 0 1.9-.3l.1-.1a2 2 0 1 1 2.8 2.8l-.1.1a1.7 1.7 0 0 0 1.2 2.9H21a2 2 0 1 1 0 4h-.2a1.7 1.7 0 0 0-1.4 1z" transform="scale(.85) translate(2 2)"/>',
 back:'<path d="M15 18l-6-6 6-6"/>',search:'<circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4"/>',bookmark:'<path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>',
 clock:'<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',doc:'<path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"/><path d="M14 3v5h5"/>',
 grid:'<rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>',
 clip:'<rect x="6" y="4" width="12" height="17" rx="2"/><path d="M9 4V3h6v1"/><path d="M9 11l2 2 4-4"/><path d="M9 16h6"/>',
 bolt:'<path d="M13 2L4 14h6l-1 8 9-12h-6z"/>',target:'<circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/>',
 flash:'<rect x="4" y="6" width="13" height="13" rx="2"/><path d="M8 6V5a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-1"/>',
 wrench:'<path d="M14 7a4 4 0 0 0-5 5l-6 6 2 2 6-6a4 4 0 0 0 5-5l-2 2-2-2 2-2z"/>',info:'<circle cx="12" cy="12" r="9"/><path d="M12 11v5"/><path d="M12 8h.01"/>',
 trash:'<path d="M4 7h16"/><path d="M9 7V5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/><path d="M6 7l1 13h10l1-13"/>',book2:'<path d="M4 5a2 2 0 0 1 2-2h13v16H6a2 2 0 0 0-2 2z"/><path d="M19 19H6"/>',
 layers:'<path d="M12 3l9 5-9 5-9-5 9-5z"/><path d="M3 13l9 5 9-5"/>',user:'<circle cx="12" cy="8" r="4"/><path d="M4 20a8 8 0 0 1 16 0"/>'}[n];
 return `<svg viewBox="0 0 24 24">${p}</svg>`}
function sb(){const d=new Date();const t=(d.getHours()%12||12)+":"+String(d.getMinutes()).padStart(2,"0");
 return `<div class="sb"><div>${t}</div><div class="ic">
  <svg viewBox="0 0 18 14"><path d="M1 13h2V8H1zM5 13h2V5H5zM9 13h2V3H9zM13 13h2V1h-2z"/></svg>
  <svg viewBox="0 0 18 14"><path d="M9 3.5c2.2 0 4.2.8 5.7 2.2l1.3-1.4A10 10 0 0 0 9 1.5 10 10 0 0 0 2 4.3l1.3 1.4A8 8 0 0 1 9 3.5zM9 7c1.1 0 2.1.4 2.9 1.2l1.3-1.4A6 6 0 0 0 9 5a6 6 0 0 0-4.2 1.8l1.3 1.4A4 4 0 0 1 9 7zm0 3.5l1.8-1.9a3 3 0 0 0-3.6 0z"/></svg>
  <svg viewBox="0 0 18 14"><rect x="1" y="3.5" width="13" height="7" rx="1.5" fill="none" stroke="currentColor"/><rect x="2.5" y="5" width="9.5" height="4" rx="0.5"/><rect x="15" y="5.5" width="1.5" height="3" rx="0.7"/></svg></div></div>`}
function donut(pct,size,inner){const r=size/2-9,c=2*Math.PI*r,off=c*(1-pct/100),cx=size/2;
 return `<div class="donut" style="width:${size}px;height:${size}px"><svg width="${size}" height="${size}"><circle cx="${cx}" cy="${cx}" r="${r}" fill="none" stroke="#222d3d" stroke-width="9"/><circle cx="${cx}" cy="${cx}" r="${r}" fill="none" stroke="#F5C518" stroke-width="9" stroke-linecap="round" stroke-dasharray="${c}" stroke-dashoffset="${off}" transform="rotate(-90 ${cx} ${cx})"/></svg><div class="ctr"><div class="pc">${pct}%</div><div class="lb">${inner}</div></div></div>`}
function shuffle(a){a=a.slice();for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]]}return a}

/* ----- onboarding ----- */
function vOnboard(){const lv=["Apprentice","Journeyman Electrician","Master Electrician"];
 return `<div class="ob">
   <img src="${MARK}" style="width:64px;margin-bottom:18px" alt="">
   <h1>Let's set up</h1><p>We'll personalize your prep. You can change this anytime in Settings.</p>
   <div class="fld"><label>Your name</label><input id="ob_name" placeholder="e.g. Jordan" value="${(app.ob.name||'').replace(/"/g,'&quot;')}"></div>
   <div class="fld"><label>What are you preparing for?</label>
     <div class="chiprow">${lv.map(l=>`<button class="lvl ${app.ob.level===l?'on':''}" data-act="oblevel" data-arg="${l}">${l.replace(' Electrician','')}</button>`).join("")}</div></div>
   <div class="fld"><label>Code edition</label><select id="ob_code"><option>2023 NEC\u00AE</option><option>2026 NEC\u00AE</option><option>2020 NEC\u00AE</option><option>2017 NEC\u00AE</option></select></div>
   <button class="btn gold" data-act="obdone">Start practicing</button>
 </div>`}

/* ----- home ----- */
function vHome(){const m=mastery(),tm=masteredCount(),tt=AQ().length,tp=tt?Math.round(tm/tt*100):0;
 return `${sb()}<div class="hbar"><div style="flex:1"><div class="welcome">Welcome back,</div>
   <div class="name">${st.name||"Electrician"} <img src="${MARK}" alt=""></div></div><div class="icbtn" data-act="noop">${I("bell")}</div></div>
 <div class="pad">
   <div class="rowsb"><div class="h">Your Progress</div><div class="a" data-act="go" data-arg="results">See all</div></div>
   <div class="card"><div class="pgrid">${donut(m,118,"Overall")}<div class="stats">
     <div class="stat"><span class="k">Correct</span><span class="v good">${st.cor}</span></div>
     <div class="stat"><span class="k">Incorrect</span><span class="v bad">${st.inc}</span></div>
     <div class="stat"><span class="k">Streak</span><span class="v">${streak()} \uD83D\uDD25</span></div></div></div></div>
   <div class="card lic"><div class="top"><div><div class="lt">${st.level}</div><div class="ls">${st.code}</div></div>
     <button class="chgbtn" data-act="settings">Change</button></div>
     <div class="pbar"><i style="width:${tp}%"></i></div>
     <div class="meta"><span>${tm} of ${tt} Topics Mastered</span><span>${tp}%</span></div></div>
   <button class="card" data-act="apt" style="display:block;width:100%;text-align:left;border:1px solid rgba(245,197,24,.30);margin-top:13px"><div style="display:flex;align-items:center;gap:12px"><div style="width:42px;height:42px;border-radius:11px;background:rgba(245,197,24,.13);display:flex;align-items:center;justify-content:center;color:var(--gold);flex-shrink:0">${I("clip")}</div><div><div style="font-family:Poppins;font-weight:700;font-size:14.5px;color:#fff">Trying to get into the apprenticeship?</div><div style="font-size:12.5px;color:var(--mut);margin-top:2px">Prep for the IBEW aptitude test — algebra &amp; reading</div></div></div></button>
   ${ladderPanel()}
   <div class="tiles">
     <button class="tile" data-act="go" data-arg="practice"><div class="ti">${I("practice")}</div><div class="tt">Practice</div><div class="ts">Create a custom practice test</div></button>
     <button class="tile" data-act="mockintro"><div class="ti">${I("clip")}</div><div class="tt">Mock Exam</div><div class="ts">Take a full length practice exam</div></button>
     <button class="tile" data-act="go" data-arg="study"><div class="ti">${I("book2")}</div><div class="tt">Study</div><div class="ts">Review by topic or code sections</div></button>
     <button class="tile" data-act="flash" data-arg="all"><div class="ti">${I("flash")}</div><div class="tt">Flashcards</div><div class="ts">Learn and review key concepts</div></button>
   </div></div>`}

/* ----- practice setup ----- */
function vPractice(){
 const bn=st.bookmarks.length,wn=st.wrong.length;
 const modes=[
  {a:"mode",arg:"quick",ic:"bolt",t:"Quick Practice",s:"10 mixed questions"},
  {a:"mode",arg:"mixed",ic:"grid",t:"Full Mixed",s:`All ${AQ().length} questions, shuffled`},
  {a:"mode",arg:"weak",ic:"target",t:"Weak Areas",s:"Focus your lowest-scoring topics"},
  {a:"mode",arg:"book",ic:"bookmark",t:"Bookmarked",s:bn?`${bn} saved question${bn>1?"s":""}`:"None saved yet"},
  {a:"mode",arg:"review",ic:"clock",t:"Review Mistakes",s:wn?`${wn} to retry`:"No mistakes to review"}];
 return `${sb()}<div class="hbar"><div class="t">Practice</div></div>
 <div class="pad">
   ${modes.map(m=>`<div class="mcard" data-act="${m.a}" data-arg="${m.arg}"><div class="mi">${I(m.ic)}</div>
     <div class="mn"><div class="mt2">${m.t}</div><div class="ms">${m.s}</div></div><div class="cv">\u203A</div></div>`).join("")}
   <div class="rowsb"><div class="h">Practice by Topic</div></div>
   ${CATS.map(c=>{const n=AQ().filter(q=>q.cat===c).length,mm=catMastery(c);
     return `<div class="arow" data-act="topic" data-arg="${c}"><div style="flex:1"><div class="an" style="font-size:14.5px">${c}</div>
       <div class="pbar" style="margin:7px 0 0"><i style="width:${mm}%"></i></div></div>
       <div style="text-align:right;margin-left:12px"><div class="ap">${mm}%</div><div class="ap" style="font-size:11px">${n} Q</div></div><div class="cv">\u203A</div></div>`}).join("")}
   <div style="height:8px"></div></div>`}

/* ----- study ----- */
function vStudy(){const topics=app.studyTab==="topics";
 return `${sb()}<div class="hbar"><div class="t">Study</div></div>
 <div class="pad">
   <div class="search">${I("search")}<input id="ssearch" placeholder="Search topics or code sections" value="${app.studyQ.replace(/"/g,'&quot;')}" oninput="filterStudy(this.value)"></div>
   <div class="toggle"><button class="${topics?'on':''}" data-act="stab" data-arg="topics">NEC\u00AE Topics</button><button class="${!topics?'on':''}" data-act="stab" data-arg="sections">Code Sections</button></div>
   <div id="study-list">${studyList()}</div></div>`}
function studyList(){const q=app.studyQ.toLowerCase();
 if(app.studyTab==="topics"){
   return ARTICLES.filter(a=>(a.num+" "+a.sub).toLowerCase().includes(q)).map(a=>{
     const pool=AQ().filter(x=>a.cats.includes(x.cat));const done=pool.filter(x=>(st.qstat[x.id]||{}).cor>0).length;
     return `<div class="arow" data-act="artpractice" data-arg="${a.id}"><div class="ai">${I("doc")}</div>
       <div style="flex:1"><div class="an">${a.num}</div><div class="as">${a.sub}</div></div>
       <div class="ap">${done} / ${pool.length}</div><div class="cv">\u203A</div></div>`}).join("")||emptyRow("No topics match.");
 } else {
   return LESSONS.filter(l=>(l.t+" "+l.cat).toLowerCase().includes(q)).map(l=>{const done=st.read.includes(l.id);
     return `<div class="arow" data-act="lesson" data-arg="${l.id}"><div class="ai">${I("book2")}</div>
       <div style="flex:1"><div class="an">${l.t}</div><div class="as">${l.cat} \u00B7 ${l.mins} min${done?' \u00B7 <span style="color:var(--good)">\u2713 read</span>':''}</div></div><div class="cv">\u203A</div></div>`}).join("")||emptyRow("No sections match.");
 }}
function emptyRow(t){return `<div class="empty">${t}</div>`}
function filterStudy(v){app.studyQ=v;const el=document.getElementById("study-list");if(el)el.innerHTML=studyList()}

/* ----- results ----- */
function vResults(){const a=avg();
 return `${sb()}<div class="hbar"><div class="t">Results</div><div class="seg" data-act="noop">All Time</div></div>
 <div class="pad">
   <div class="card"><div class="pgrid">${donut(a,118,"Avg Score")}<div class="stats">
     <div class="stat"><span class="k">Total Tests</span><span class="v">${st.tests}</span></div>
     <div class="stat"><span class="k">Correct</span><span class="v good">${st.testCor}</span></div>
     <div class="stat"><span class="k">Incorrect</span><span class="v bad">${st.testInc}</span></div></div></div></div>
   <div class="rowsb"><div class="h">Score Over Time</div></div>
   <div class="card">${chart(st.mocks)}</div>
   <div class="rowsb"><div class="h">Topic Mastery</div></div>
   ${CATS.filter(c=>st.cat[c]&&st.cat[c].seen).map(c=>`<div class="arow" style="cursor:default;border:0;padding:8px 2px"><div style="flex:1"><div class="an" style="font-size:14px">${c}</div><div class="pbar" style="margin:7px 0 0"><i style="width:${catMastery(c)}%"></i></div></div><div class="ap" style="margin-left:12px">${st.cat[c].cor}/${st.cat[c].seen}</div></div>`).join("")||'<div class="empty">Answer questions to build topic mastery.</div>'}
   <div style="height:8px"></div></div>`}
function chart(vals){if(!vals.length)return '<div class="empty">Take a mock exam to start tracking your scores.</div>';
 const w=320,h=130;const pts=vals.map((v,i)=>[vals.length<2?w/2:i/(vals.length-1)*w,h-v/100*h]);
 const line=pts.map(p=>p[0].toFixed(0)+","+p[1].toFixed(0)).join(" ");
 const dots=pts.map(p=>`<circle cx="${p[0].toFixed(0)}" cy="${p[1].toFixed(0)}" r="3" fill="#F5C518"/>`).join("");
 const ylabs=[100,75,50,25,0].map((y,i)=>`<div class="yl" style="top:${i/4*100}%">${y}%</div>`).join("");
 const grids=[0,25,50,75,100].map(p=>`<div class="grid" style="top:${(100-p)}%"></div>`).join("");
 return `<div class="chart">${ylabs}${grids}<svg viewBox="0 0 ${w} ${h}" preserveAspectRatio="none"><polyline fill="none" stroke="#F5C518" stroke-width="2.5" stroke-linejoin="round" points="${line}"/>${dots}</svg></div>`}

/* ----- more / glossary / settings ----- */
function vMore(){return `${sb()}<div class="hbar"><div class="t">More</div></div><div class="pad">
   <div class="mcard" data-act="calc"><div class="mi">${I("wrench")}</div><div class="mn"><div class="mt2">Calculators</div><div class="ms">Ohm's Law, voltage drop, fill, sizing</div></div><div class="cv">\u203A</div></div>
   <div class="mcard" data-act="apt"><div class="mi">${I("clip")}</div><div class="mn"><div class="mt2">IBEW Aptitude Prep</div><div class="ms">Get into the apprenticeship — algebra &amp; reading</div></div><div class="cv">›</div></div>
   <div class="mcard" data-act="worked"><div class="mi">${I("wrench")}</div><div class="mn"><div class="mt2">Worked Examples</div><div class="ms">Step-by-step code calculations</div></div><div class="cv">›</div></div>
   <div class="mcard" data-act="flash" data-arg="all"><div class="mi">${I("flash")}</div><div class="mn"><div class="mt2">Flashcards</div><div class="ms">Flip through the question bank</div></div><div class="cv">\u203A</div></div>
   <div class="mcard" data-act="glossary"><div class="mi">${I("book2")}</div><div class="mn"><div class="mt2">Glossary</div><div class="ms">${GLOSSARY.length} key terms in plain language</div></div><div class="cv">\u203A</div></div>
   <div class="mcard" data-act="settings"><div class="mi">${I("user")}</div><div class="mn"><div class="mt2">Settings</div><div class="ms">Name, exam level, code edition</div></div><div class="cv">\u203A</div></div>
   <div class="mcard" data-act="about"><div class="mi">${I("info")}</div><div class="mn"><div class="mt2">About Knowatt</div></div><div class="cv">\u203A</div></div>
 </div>`}
function vGlossary(){return `<div class="qwrap"><div class="qhead"><div class="icbtn" data-act="go" data-arg="more">${I("back")}</div><div class="ttl">Glossary</div><div style="width:40px"></div></div>
   <div class="pad">${GLOSSARY.map(g=>`<div class="gterm"><div class="gt">${g.t}</div><div class="gd">${g.d}</div></div>`).join("")}</div></div>`}
function vSettings(){const lv=["Apprentice","Journeyman Electrician","Master Electrician"];
 return `<div class="qwrap"><div class="qhead"><div class="icbtn" data-act="go" data-arg="more">${I("back")}</div><div class="ttl">Settings</div><div style="width:40px"></div></div>
   <div class="pad">
     <div class="fld"><label>Name</label><input id="set_name" value="${(st.name||'').replace(/"/g,'&quot;')}"></div>
     <div class="fld"><label>Exam level</label><select id="set_level">${lv.map(l=>`<option ${st.level===l?'selected':''}>${l}</option>`).join("")}</select></div>
     <div class="fld"><label>Code edition</label><select id="set_code">${["2023 NEC\u00AE","2026 NEC\u00AE","2020 NEC\u00AE","2017 NEC\u00AE"].map(c=>`<option ${st.code===c?'selected':''}>${c}</option>`).join("")}</select></div>
     <button class="btn gold" data-act="savesettings">Save</button>
     <button class="btn ghost" data-act="reset" style="color:var(--bad)">Reset all progress</button>
   </div></div>`}

/* ----- quiz engine ----- */
function vApt(){const best=(st.aptScores&&st.aptScores.length)?Math.max.apply(null,st.aptScores):null;
 return `<div class="qwrap"><div class="qhead"><div class="icbtn" data-act="go" data-arg="more">${I("back")}</div><div class="ttl">IBEW Aptitude Prep</div><div style="width:40px"></div></div>
  <div class="pad">
   <div class="card"><div style="font-family:Poppins;font-weight:700;font-size:16px">The Aptitude Test</div>
    <div style="font-size:13.5px;color:#cdd7e2;line-height:1.6;margin-top:8px">The IBEW / Electrical Training Alliance aptitude test is the gateway <b>into</b> an apprenticeship — taken before you start. It has two sections and requires <b>no electrical knowledge</b>:</div>
    <div style="margin-top:11px;display:flex;flex-direction:column;gap:8px">
     <div style="background:#0f1830;border:1px solid #20304d;border-radius:11px;padding:11px 13px"><div style="font-weight:700;color:#fff">Algebra &amp; Functions</div><div style="font-size:12.5px;color:var(--mut);margin-top:3px">33 questions · 46 minutes</div></div>
     <div style="background:#0f1830;border:1px solid #20304d;border-radius:11px;padding:11px 13px"><div style="font-weight:700;color:#fff">Reading Comprehension</div><div style="font-size:12.5px;color:var(--mut);margin-top:3px">36 questions · 51 minutes</div></div>
    </div>
    <div style="font-size:12.5px;color:var(--mut);line-height:1.6;margin-top:11px">Scored on a <b>Stanine 1–9</b> scale. Most locals require a <b>4 or higher</b> to be invited for an interview. No calculator — pencil and scratch paper only. Wrong answers are not penalized, so never leave a blank. <i>Format can vary slightly by local — confirm with yours.</i></div>
   </div>
   ${best!=null?`<div class="card" style="text-align:center"><div style="font-size:12.5px;color:var(--mut)">Best practice mock</div><div style="font-size:26px;font-weight:800;color:var(--gold);font-family:Poppins">${best}%</div></div>`:""}
   <button class="btn gold" data-act="aptmath">Algebra &amp; Functions — Practice</button>
   <button class="btn gold" data-act="aptread">Reading Comprehension — Practice</button>
   <button class="btn ghost" data-act="aptmock">Full Timed Mock · 20 Q · 25 min</button>
   <div style="font-size:11.5px;color:var(--mut);text-align:center;margin-top:10px;line-height:1.5">Practice gives instant feedback and worked solutions. The timed mock mirrors the real two-section structure on a shorter scale.</div>
  </div></div>`}
function startApt(sec){const pool=shuffle((sec==="Math"?APT_MATH:APT_READ).slice());startQuiz(pool,"practice","Aptitude · "+(sec==="Math"?"Algebra":"Reading"),{nec:false,back:"apt"})}
function startAptMock(){const m=shuffle(APT_MATH.slice()).slice(0,12),r=shuffle(APT_READ.slice()).slice(0,8);startQuiz(shuffle(m.concat(r)),"exam","Aptitude Mock",{nec:false,dur:1500,back:"apt"})}
function vWorked(){return `<div class="qwrap"><div class="qhead"><div class="icbtn" data-act="go" data-arg="more">${I("back")}</div><div class="ttl">Worked Examples</div><div style="width:40px"></div></div>
  <div class="pad"><div style="font-size:13px;color:var(--mut);line-height:1.6;margin-bottom:8px">Step-by-step calculations — each one walks the <b>what</b>, the <b>how</b>, and the <b>why</b>, one step at a time.</div>
  ${WORKED.map(w=>`<div class="mcard" data-act="workedone" data-arg="${w.id}"><div class="mi">${I("wrench")}</div><div class="mn"><div class="mt2">${w.t}</div><div class="ms">${w.scenario}</div></div><div class="cv">›</div></div>`).join("")}
  </div></div>`}
function vWorkedDetail(){const w=WORKED.find(x=>x.id===app.sub2);const n=app.wstep||1,total=w.steps.length,shown=w.steps.slice(0,n),done=n>=total;
 return `<div class="qwrap"><div class="qhead"><div class="icbtn" data-act="go" data-arg="worked">${I("back")}</div><div class="ttl">Worked Example</div><div style="width:40px"></div></div>
  <div class="pad">
   <div class="card"><div style="font-family:Poppins;font-weight:700;font-size:15.5px">${w.t}</div><div style="font-size:13.5px;color:#cdd7e2;line-height:1.6;margin-top:7px">${w.scenario}</div></div>
   ${shown.map((s,i)=>`<div class="card" style="border-left:3px solid var(--gold)"><div style="font-weight:700;color:var(--gold);font-size:11px;text-transform:uppercase;letter-spacing:.5px">Step ${i+1} of ${total}</div><div style="font-weight:600;color:#fff;margin-top:4px">${s.h}</div><div style="font-size:13.5px;color:#cdd7e2;line-height:1.6;margin-top:5px">${s.d}</div></div>`).join("")}
   ${done?`<div class="card" style="background:rgba(245,197,24,.1);border-color:rgba(245,197,24,.35)"><div style="font-weight:700;color:var(--gold)">Answer</div><div style="font-size:14.5px;color:#fff;margin-top:5px">${w.answer}</div><div style="margin-top:9px">${w.refs.map(r=>`<span class="ref" style="margin-right:6px">${r}</span>`).join("")}</div></div>`:""}
   ${done?`<button class="btn ghost" data-act="worked">Back to examples</button>`:`<button class="btn gold" data-act="wstep">Reveal next step</button>`}
  </div></div>`}
function poolFor(mode,arg){
 if(mode==="quick")return shuffle(AQ()).slice(0,10);
 if(mode==="mixed")return shuffle(AQ());
 if(mode==="weak"){const ranked=CATS.map(c=>({c,m:st.cat[c]&&st.cat[c].seen?st.cat[c].cor/st.cat[c].seen:-1})).sort((a,b)=>a.m-b.m).slice(0,3).map(x=>x.c);
   return shuffle(AQ().filter(q=>ranked.includes(q.cat))).slice(0,15)}
 if(mode==="book")return shuffle(AQ().filter(q=>st.bookmarks.includes(q.id)));
 if(mode==="review")return shuffle(AQ().filter(q=>st.wrong.includes(q.id)));
 if(mode==="topic")return shuffle(AQ().filter(q=>q.cat===arg));
 return shuffle(AQ())}
function startMode(mode,arg){const pool=poolFor(mode,arg);
 if(!pool.length){alert(mode==="book"?"No bookmarked questions yet. Tap the bookmark on a question to save it.":"Nothing to review yet \u2014 answer some questions first.");return}
 startQuiz(pool,"practice",arg||"Practice")}
function startQuiz(pool,mode,label,opts){opts=opts||{};app.sub=null;app.fc=null;
 app.quiz={pool,mode,label,idx:0,chosen:null,answered:false,results:[],done:false,showWhy:true,start:Date.now(),dur:opts.dur!=null?opts.dur:(mode==="exam"?7200:0),nec:opts.nec!==false,back:opts.back||(mode==="exam"?"home":"practice")};render()}
function vQuiz(){const Q=app.quiz,q=Q.pool[Q.idx],L=["A","B","C","D"],exam=Q.mode==="exam";
 const opts=q.opts.map((o,i)=>{let c="opt";if(Q.answered){if(i===q.correct)c+=" correct";else if(i===Q.chosen)c+=" wrong"}else if(i===Q.chosen)c+=" sel";
   const ck=Q.answered&&i===q.correct?"\u2713":(Q.answered&&i===Q.chosen?"\u2715":"");
   return `<button class="${c}" data-act="answer" data-arg="${i}" ${Q.answered?'disabled':''}><span class="ltr">${L[i]}</span><span class="otext">${o}</span><span class="ck">${ck}</span></button>`}).join("");
 const showFb=Q.answered&&!exam,correct=Q.answered&&Q.chosen===q.correct,canNext=Q.answered||(exam&&Q.chosen!=null);
 const bk=st.bookmarks.includes(q.id),back=Q.back||(exam?"home":"practice");
 return `<div class="qwrap"><div class="qhead"><div class="icbtn" data-act="go" data-arg="${back}">${I("back")}</div>
   <div class="ttl">${Q.label||(exam?"Mock Exam":"Practice")}</div>${Q.nec?`<div class="icbtn" data-act="bookmark" data-arg="${q.id}" style="${bk?'color:var(--gold)':''}">${I("bookmark")}</div>`:`<div style="width:40px"></div>`}</div>
   <div class="qmeta"><span>Question ${Q.idx+1} of ${Q.pool.length}</span><span class="tm">${I("clock")}<span id="qtime">0:00</span></span></div>
   <div class="qtrack"><i style="width:${Q.idx/Q.pool.length*100}%"></i></div>
   <div class="qbody">${q.passage?`<div style="background:#0f1830;border:1px solid #20304d;border-radius:12px;padding:12px 14px;margin-bottom:12px;font-size:13.5px;line-height:1.6;color:#cdd7e2;max-height:240px;overflow:auto"><div style="font-weight:700;color:#fff;margin-bottom:6px;font-family:Poppins">${q.passageTitle||"Passage"}</div>${q.passage}</div>`:""}<div class="qtext">${q.q}</div>${opts}
     ${showFb?`<div class="fb ${correct?'good':'bad'}"><div class="ft"><span class="fh">${correct?'Correct!':'Not quite'}</span>${Q.nec?`<span class="bm ${bk?'on':''}" data-act="bookmark" data-arg="${q.id}">${I("bookmark")}</span>`:""}</div><div class="fw" id="whybox">${q.why}${q.ref?`<br>${citeFor(q.ref)}`:""}</div></div>`:""}
   </div>
   <div class="qbtns">${showFb?`<button class="dark" data-act="togglewhy">Explanation</button>`:`<button class="dark" data-act="go" data-arg="${back}">Quit</button>`}
     <button class="gold" data-act="next" ${canNext?'':'disabled style="opacity:.45"'}>${Q.idx+1>=Q.pool.length?"Finish":"Next"}</button></div></div>`}
function answer(i){const Q=app.quiz;if(Q.answered)return;i=+i;
 if(Q.mode==="exam"){Q.chosen=i;render();return}
 const q=Q.pool[Q.idx];Q.chosen=i;Q.answered=true;const ok=i===q.correct;Q.results.push({q,chosen:i,ok});if(Q.nec)recordAnswer(q,ok);render()}
function togglewhy(){const Q=app.quiz;Q.showWhy=!Q.showWhy;const b=document.getElementById("whybox");if(b)b.style.display=Q.showWhy?"":"none"}
function next(){const Q=app.quiz;
 if(Q.mode==="exam"){if(Q.chosen==null)return;const q=Q.pool[Q.idx];const ok=Q.chosen===q.correct;Q.results.push({q,chosen:Q.chosen,ok});if(Q.nec)recordAnswer(q,ok)}
 Q.idx++;Q.chosen=null;Q.answered=false;Q.showWhy=true;if(Q.idx>=Q.pool.length)finish();else render()}
function finish(){stopTimer();const Q=app.quiz;const cor=Q.results.filter(r=>r.ok).length;Q.score=Math.round(cor/Q.pool.length*100);Q.done=true;
 if(Q.mode==="exam"){if(Q.nec){st.tests++;st.testCor+=cor;st.testInc+=(Q.pool.length-cor);st.mocks.push(Q.score);if(st.mocks.length>16)st.mocks=st.mocks.slice(-16)}else{st.aptScores=st.aptScores||[];st.aptScores.push(Q.score);if(st.aptScores.length>16)st.aptScores=st.aptScores.slice(-16)}save()}render()}
function vDone(){const Q=app.quiz,cor=Q.results.filter(r=>r.ok).length,pass=Q.score>=75,missed=Q.results.filter(r=>!r.ok),apt=!Q.nec;
 return `<div class="qwrap"><div class="qhead"><div class="icbtn" data-act="go" data-arg="${apt?'more':'home'}">${I("back")}</div><div class="ttl">Results</div><div style="width:40px"></div></div>
   <div class="pad" style="flex:1"><div class="card" style="text-align:center;margin-top:8px">${donut(Q.score,128,"Score")}
     <div style="margin-top:12px;color:var(--mut)">${cor} of ${Q.pool.length} correct</div>
     ${Q.mode==="exam"?(apt?`<div style="margin-top:10px;display:inline-block;padding:6px 13px;border-radius:20px;font-weight:700;font-size:13px;color:var(--gold);background:rgba(245,197,24,.12)">Practice mock — most locals want a Stanine 4+</div>`:`<div style="margin-top:10px;display:inline-block;padding:6px 13px;border-radius:20px;font-weight:700;font-size:13px;${pass?'color:var(--good);background:rgba(55,211,154,.12)':'color:var(--bad);background:rgba(255,91,91,.1)'}">${pass?"Passing range":"Below typical pass (~75%)"}</div>`):""}</div>
     ${missed.length?`<div class="rowsb"><div class="h">Review \u2014 missed (${missed.length})</div></div>${missed.map(r=>`<div class="card" style="margin-bottom:11px"><div style="font-weight:600;font-size:14.5px;margin-bottom:10px">${r.q.q}</div><div class="opt correct" style="margin:0 0 8px"><span class="ltr">${["A","B","C","D"][r.q.correct]}</span><span class="otext">${r.q.opts[r.q.correct]}</span><span class="ck">\u2713</span></div><div class="fb good"><div class="fw">${r.q.why}${r.q.ref?`<br>${citeFor(r.q.ref)}`:""}</div></div></div>`).join("")}`:`<div class="card" style="text-align:center;color:var(--good);font-weight:600;margin-top:6px">Perfect \u2014 every one correct.</div>`}
     <button class="btn gold" data-act="${apt?'apt':(Q.mode==='exam'?'mockintro':'go')}" ${apt?'':'data-arg="practice"'}>${apt?'Back to Aptitude Prep':(Q.mode==='exam'?'Take another exam':'More practice')}</button>
     ${apt?"":`<button class="btn ghost" data-act="go" data-arg="results">View results</button>`}</div></div>`}

/* ----- mock intro ----- */
function vMockIntro(){return `<div class="qwrap"><div class="qhead"><div class="icbtn" data-act="go" data-arg="home">${I("back")}</div><div class="ttl">Mock Exam</div><div style="width:40px"></div></div>
   <div class="mock"><div class="big-ic">${I("clip")}</div><div class="mt">${st.level}<br>Full Length Exam</div>
     <div class="mlist"><div class="mli">${I("clock")}<span>${MOCKN()} Questions</span></div><div class="mli">${I("clock")}<span>2 Hour Time Limit</span></div><div class="mli">${I("grid")}<span>Mixed NEC\u00AE Topics</span></div><div class="mli">${I("doc")}<span>Simulates real exam experience</span></div></div>
     <button class="sp-btn" data-act="startmock">Start Exam</button></div></div>`}

/* ----- lesson ----- */
function vLesson(){const l=LESSONS.find(x=>x.id===app.sub2);
 return `<div class="qwrap"><div class="qhead"><div class="icbtn" data-act="go" data-arg="study">${I("back")}</div><div class="ttl">${l.cat}</div><div style="width:40px"></div></div>
   <div class="pad article"><h2>${l.t}</h2>${l.body}
     <div class="keybox"><div class="kh">Key Takeaways</div><ul style="margin:0;padding-left:18px">${l.keys.map(k=>`<li>${k}</li>`).join("")}</ul></div>
     <div>${l.refs.map(r=>`<span class="ref" style="margin-right:6px">${r}</span>`).join("")}</div>
     <button class="btn gold" data-act="lessoncat" data-arg="${l.cat}">Practice this topic</button>
     <button class="btn ghost" data-act="read" data-arg="${l.id}">${st.read.includes(l.id)?"\u2713 Marked as read":"Mark as read"}</button></div></div>`}

/* ----- flashcards ----- */
function startFlash(){app.fc={pool:shuffle(AQ()),idx:0,flip:false};app.sub=null;app.quiz=null;render()}
function vFlash(){const F=app.fc,q=F.pool[F.idx];
 return `<div class="qwrap"><div class="qhead"><div class="icbtn" data-act="go" data-arg="home">${I("back")}</div><div class="ttl">Flashcards</div><div style="width:40px"></div></div>
   <div class="qmeta"><span>Card ${F.idx+1} of ${F.pool.length}</span><span>${q.cat}</span></div>
   <div class="flash"><div class="fcard" data-act="flip">${F.flip?`<div class="fa">${q.opts[q.correct]}</div><div class="fwhy">${q.why}<br>${citeFor(q.ref)}</div>`:`<div class="fq">${q.q}</div><div class="fhint">Tap to reveal the answer</div>`}</div>
     <button class="sp-btn" data-act="fcnext">${F.idx+1>=F.pool.length?"Finish":"Next card"}</button></div></div>`}
function flip(){app.fc.flip=!app.fc.flip;render()}
function fcnext(){const F=app.fc;if(F.idx+1>=F.pool.length){go("home");return}F.idx++;F.flip=false;render()}

/* ----- calculators ----- */
function vCalc(){const opts=Object.keys(CM).map(k=>`<option value="${CM[k]}">${k}</option>`).join("");
 return `<div class="qwrap"><div class="qhead"><div class="icbtn" data-act="go" data-arg="more">${I("back")}</div><div class="ttl">Calculators</div><div style="width:40px"></div></div>
   <div class="pad">
     <div class="rowsb"><div class="h">Ohm's Law / Power</div></div>
     <div class="card"><div style="color:var(--mut);font-size:13px;margin-bottom:12px">Enter any two values.</div><div class="twocol">
       <div class="fld"><label>Voltage (V)</label><input id="o_v" type="number" inputmode="decimal"></div><div class="fld"><label>Current (I)</label><input id="o_i" type="number" inputmode="decimal"></div>
       <div class="fld"><label>Resistance (\u03A9)</label><input id="o_r" type="number" inputmode="decimal"></div><div class="fld"><label>Power (W)</label><input id="o_p" type="number" inputmode="decimal"></div></div>
       <button class="btn gold" data-act="ohm" style="margin-top:2px">Calculate</button><div id="o_out"></div></div>
     <div class="rowsb"><div class="h">Voltage Drop</div></div>
     <div class="card"><div class="twocol">
       <div class="fld"><label>Material</label><select id="v_mat"><option value="12.9">Copper</option><option value="21.2">Aluminum</option></select></div>
       <div class="fld"><label>Phase</label><select id="v_ph"><option value="2">Single-phase</option><option value="1.732">Three-phase</option></select></div>
       <div class="fld"><label>Conductor</label><select id="v_cm">${opts}</select></div>
       <div class="fld"><label>System volts</label><input id="v_v" type="number" inputmode="decimal"></div>
       <div class="fld"><label>Load (A)</label><input id="v_i" type="number" inputmode="decimal"></div>
       <div class="fld"><label>One-way length (ft)</label><input id="v_l" type="number" inputmode="decimal"></div></div>
       <button class="btn gold" data-act="vd" style="margin-top:2px">Calculate</button><div id="v_out"></div></div>
     <div class="rowsb"><div class="h">Continuous-Load Sizer</div></div>
     <div class="card"><div class="twocol">
       <div class="fld"><label>Continuous load (A)</label><input id="cl_c" type="number" inputmode="decimal"></div>
       <div class="fld"><label>Noncontinuous (A)</label><input id="cl_n" type="number" inputmode="decimal"></div></div>
       <button class="btn gold" data-act="contload" style="margin-top:2px">Calculate</button><div id="cl_out"></div></div>
     <div class="rowsb"><div class="h">Conduit Fill</div></div>
     <div class="card"><div class="twocol">
       <div class="fld"><label>Total conductor area (in\u00B2)</label><input id="cf_a" type="number" inputmode="decimal"></div>
       <div class="fld"><label>Raceway internal area (in\u00B2)</label><input id="cf_r" type="number" inputmode="decimal"></div>
       <div class="fld"><label># of conductors</label><input id="cf_n" type="number" inputmode="numeric"></div></div>
       <button class="btn gold" data-act="fill" style="margin-top:2px">Calculate</button><div id="cf_out"></div>
       <div class="disc">Enter conductor and raceway areas from your conductor/raceway data; this applies the 53% / 31% / 40% fill limits.</div></div>
   </div></div>`}
function fnum(id){const x=parseFloat(document.getElementById(id).value);return isNaN(x)?null:x}
function ohm(){let v=fnum("o_v"),i=fnum("o_i"),r=fnum("o_r"),p=fnum("o_p");const o=document.getElementById("o_out");
 if([v,i,r,p].filter(x=>x!=null).length<2){o.innerHTML='<div class="out" style="color:var(--bad)">Enter at least two values.</div>';return}
 for(let k=0;k<6;k++){if(v==null&&i!=null&&r!=null)v=i*r;if(v==null&&p!=null&&i!=null)v=p/i;if(v==null&&p!=null&&r!=null)v=Math.sqrt(p*r);
  if(i==null&&v!=null&&r!=null)i=v/r;if(i==null&&p!=null&&v!=null)i=p/v;if(i==null&&p!=null&&r!=null)i=Math.sqrt(p/r);
  if(r==null&&v!=null&&i!=null)r=v/i;if(r==null&&v!=null&&p!=null)r=v*v/p;if(r==null&&p!=null&&i!=null)r=p/(i*i);
  if(p==null&&v!=null&&i!=null)p=v*i;if(p==null&&i!=null&&r!=null)p=i*i*r;if(p==null&&v!=null&&r!=null)p=v*v/r}
 const f=x=>x==null?"\u2014":(Math.round(x*1000)/1000).toLocaleString();
 o.innerHTML=`<div class="out"><div class="twocol"><div>V = <b class="b2">${f(v)}</b></div><div>I = <b class="b2">${f(i)}</b></div><div>R = <b class="b2">${f(r)}</b></div><div>P = <b class="b2">${f(p)}</b></div></div></div>`}
function vd(){const K=+document.getElementById("v_mat").value,mu=+document.getElementById("v_ph").value,cm=+document.getElementById("v_cm").value,v=fnum("v_v"),i=fnum("v_i"),l=fnum("v_l");const o=document.getElementById("v_out");
 if(v==null||i==null||l==null){o.innerHTML='<div class="out" style="color:var(--bad)">Fill in volts, load, and length.</div>';return}
 const d=mu*K*i*l/cm,pct=d/v*100,ok=pct<=3;
 o.innerHTML=`<div class="out"><div>Voltage drop: <b class="b2">${d.toFixed(2)} V</b></div><div style="margin-top:6px">Percentage: <b class="b2" style="color:${ok?'var(--good)':'var(--bad)'}">${pct.toFixed(2)}%</b></div><div style="color:var(--mut);margin-top:8px">At load \u2248 ${(v-d).toFixed(1)} V \u00B7 ${ok?"Within recommended 3%":"Exceeds 3% \u2014 consider up-sizing"}</div></div>`}
function contload(){const c=fnum("cl_c")||0,n=fnum("cl_n")||0,o=document.getElementById("cl_out");
 if(c+n<=0){o.innerHTML='<div class="out" style="color:var(--bad)">Enter a load.</div>';return}
 const amp=n+c*1.25,std=STDOCPD.find(s=>s>=amp)||">400";
 o.innerHTML=`<div class="out"><div>Min ampacity: <b class="b2">${amp.toFixed(1)} A</b></div><div style="margin-top:6px">Next standard OCPD: <b class="b2">${std}${typeof std==="number"?" A":""}</b></div><div style="color:var(--mut);margin-top:8px">100% \u00D7 ${n} + 125% \u00D7 ${c} = ${amp.toFixed(1)} A</div></div>`}
function fill(){const a=fnum("cf_a"),r=fnum("cf_r"),n=Math.round(fnum("cf_n")||0),o=document.getElementById("cf_out");
 if(a==null||r==null||!n){o.innerHTML='<div class="out" style="color:var(--bad)">Enter areas and count.</div>';return}
 const lim=n>=3?40:n===2?31:53,pct=a/r*100,ok=pct<=lim;
 o.innerHTML=`<div class="out"><div>Fill: <b class="b2" style="color:${ok?'var(--good)':'var(--bad)'}">${pct.toFixed(1)}%</b></div><div style="margin-top:6px">Limit (${n} conductor${n>1?"s":""}): <b>${lim}%</b></div><div style="color:var(--mut);margin-top:8px">${ok?"Within limit \u2713":"Over fill \u2014 use a larger raceway"}</div></div>`}

/* ----- timer ----- */
function startTimer(){stopTimer();app.tstart=Date.now();tick();app.tint=setInterval(tick,1000)}
function stopTimer(){if(app.tint){clearInterval(app.tint);app.tint=null}}
function tick(){const el=document.getElementById("qtime");if(!el||!app.quiz){stopTimer();return}const Q=app.quiz;let s=Math.floor((Date.now()-app.tstart)/1000);
 if(Q.mode==="exam"){let rem=Q.dur-s;if(rem<=0){stopTimer();finish();return}const hh=Math.floor(rem/3600),mm=Math.floor(rem%3600/60),ss=rem%60;el.textContent=hh+":"+String(mm).padStart(2,"0")+":"+String(ss).padStart(2,"0")}
 else{el.textContent=Math.floor(s/60)+":"+String(s%60).padStart(2,"0")}}

/* ----- nav + events ----- */
function renderNav(){const items=[["home","Home"],["practice","Practice"],["study","Study"],["results","Results"],["more","More"]];
 document.getElementById("nav").innerHTML=items.map(([r,l])=>`<button class="${app.route===r?'on':''}" data-act="go" data-arg="${r}">${I(r)}<span>${l}</span></button>`).join("")}
document.addEventListener("click",e=>{const el=e.target.closest("[data-act]");if(!el)return;const a=el.dataset.act,arg=el.dataset.arg;
 if(a==="go")go(arg);
 else if(a==="oblevel"){app.ob.level=arg;render()}
 else if(a==="obdone"){st.name=(document.getElementById("ob_name").value||"").trim();st.level=app.ob.level;st.code=document.getElementById("ob_code").value;st.onboarded=true;save();go("home")}
 else if(a==="mode")startMode(arg);
 else if(a==="topic")startMode("topic",arg);
 else if(a==="lessoncat")startMode("topic",arg);
 else if(a==="artpractice"){const ar=ARTICLES.find(x=>x.id===arg);startQuiz(shuffle(AQ().filter(q=>ar.cats.includes(q.cat))),"practice",ar.num)}
 else if(a==="mockintro"){app.sub="mockintro";app.quiz=null;app.fc=null;render()}
 else if(a==="startmock")startQuiz(shuffle(AQ()).slice(0,MOCKN()),"exam","Mock Exam");
 else if(a==="answer")answer(arg);
 else if(a==="next")next();
 else if(a==="togglewhy")togglewhy();
 else if(a==="bookmark"){toggleBookmark(arg);render()}
 else if(a==="stab"){app.studyTab=arg;app.studyQ="";render()}
 else if(a==="lesson"){app.sub="lesson";app.sub2=arg;render()}
 else if(a==="read"){if(!st.read.includes(arg)){st.read.push(arg);save()}render()}
 else if(a==="flash")startFlash();
 else if(a==="flip")flip();
 else if(a==="fcnext")fcnext();
 else if(a==="calc"){app.sub="calc";app.quiz=null;app.fc=null;render()}
 else if(a==="glossary"){app.sub="glossary";render()}
 else if(a==="settings"){app.sub="settings";render()}
 else if(a==="savesettings"){st.name=(document.getElementById("set_name").value||"").trim();st.level=document.getElementById("set_level").value;st.code=document.getElementById("set_code").value;save();go("more")}
 else if(a==="ohm")ohm();else if(a==="vd")vd();else if(a==="contload")contload();else if(a==="fill")fill();
 else if(a==="setyear"){st.year=(+arg)||null;save();render()}
 else if(a==="apt"){app.sub="apt";app.sub2=null;app.quiz=null;app.fc=null;render()}
 else if(a==="aptmath")startApt("Math");
 else if(a==="aptread")startApt("Reading");
 else if(a==="aptmock")startAptMock();
 else if(a==="worked"){app.sub="worked";app.sub2=null;app.quiz=null;app.fc=null;render()}
 else if(a==="workedone"){app.sub="workeddetail";app.sub2=arg;app.wstep=1;app.quiz=null;app.fc=null;render()}
 else if(a==="wstep"){app.wstep=(app.wstep||1)+1;render()}
 else if(a==="about")alert("Knowatt\n\nQuestions and explanations are written and verified for accuracy and structured around the what, how, and why. References cite NEC article numbers \u2014 note the 2026 edition reorganized where some articles live (e.g., load calculations moved from 220 to 120), so always confirm against the edition your jurisdiction has adopted. A study aid, not the Code.\n\nThe apprenticeship path shown is a general Inside Wireman progression \u2014 follow your local and electrical training ALLIANCE curriculum for specifics.\n\nNot affiliated with NFPA, the NEC\u00AE, the electrical training ALLIANCE, or the IBEW. All marks belong to their respective owners.");
 else if(a==="reset"){if(confirm("Reset all progress? This cannot be undone.")){const keep={onboarded:st.onboarded,name:st.name,level:st.level,code:st.code};st=Object.assign(fresh(),keep);save();go("home")}}
});
if(st.onboarded){/* returning users skip splash button but splash still shows until tapped */}
</script>

<script>if("serviceWorker" in navigator){window.addEventListener("load",function(){navigator.serviceWorker.register("/sw.js").catch(function(){});});}</script>

<!-- KNOWATT cloud layer: auth + cross-device sync + paywall gate -->
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script>
(function(){
  const SUPABASE_URL="https://lvouhkakhudbvxepcfif.supabase.co", SUPABASE_ANON_KEY="sb_publishable_N7-sgBOxu0zADFuDltZi6g_8ieLMCKL", KEY="knowatt_v3";
  if(!window.supabase){console.warn("supabase-js not loaded");return;}
  const sb=window.supabase.createClient(SUPABASE_URL,SUPABASE_ANON_KEY);
  window.knowattSB=sb; window.knowattIsPro=false;
  let user=null, pushTimer=null;
  const rawSet=localStorage.setItem.bind(localStorage);
  function schedulePush(delay=1500){
    if(!user) return; clearTimeout(pushTimer);
    pushTimer=setTimeout(async()=>{
      try{const raw=localStorage.getItem(KEY); if(!raw) return;
        await sb.from("progress").upsert({user_id:user.id,data:JSON.parse(raw),updated_at:new Date().toISOString()});
      }catch(e){console.warn("sync push failed",e);}
    },delay);
  }
  localStorage.setItem=function(k,v){rawSet(k,v); if(k===KEY) schedulePush();};
  async function pullRemote(){
    try{
      const {data,error}=await sb.from("progress").select("data").eq("user_id",user.id).maybeSingle();
      if(error){console.warn(error);return;}
      const remote=(data&&data.data&&Object.keys(data.data).length)?JSON.stringify(data.data):null;
      if(remote){ if(localStorage.getItem(KEY)!==remote){ rawSet(KEY,remote); location.reload(); } }
      else { schedulePush(0); }
    }catch(e){console.warn(e);}
  }
  async function refreshPro(){
    if(!user){window.knowattIsPro=false;document.body.classList.add("kw-free");document.body.classList.remove("kw-pro");return;}
    try{
      const {data}=await sb.from("profiles").select("is_pro,pro_until").eq("id",user.id).maybeSingle();
      window.knowattIsPro=!!(data&&data.is_pro&&(!data.pro_until||new Date(data.pro_until)>new Date()));
    }catch(e){window.knowattIsPro=false;}
    document.body.classList.toggle("kw-pro",window.knowattIsPro);
    document.body.classList.toggle("kw-free",!window.knowattIsPro);
  }
  async function signIn(){
    const email=prompt("Enter your email — we'll send a magic sign-in link (creates your account + syncs progress):");
    if(!email) return;
    const {error}=await sb.auth.signInWithOtp({email,options:{emailRedirectTo:location.href.split("#")[0]}});
    alert(error?("Error: "+error.message):"Check your email for your Knowatt sign-in link.");
  }
  async function signOut(){await sb.auth.signOut();location.reload();}
  function renderAuth(){
    let el=document.getElementById("kw-auth");
    if(!el){el=document.createElement("div");el.id="kw-auth";
      el.style.cssText="position:fixed;top:max(8px,env(safe-area-inset-top));right:10px;z-index:99999;";
      document.body.appendChild(el);}
    const bs="background:#0b1f3a;color:#f5c542;border:1px solid #f5c542;border-radius:999px;padding:6px 12px;font:600 12px system-ui,-apple-system,sans-serif;cursor:pointer;box-shadow:0 2px 8px rgba(0,0,0,.3)";
    el.innerHTML=user?('<button id="kwo" style="'+bs+'">'+user.email.split("@")[0]+' · Sign out</button>')
                     :('<button id="kwi" style="'+bs+'">Sign in / Sync</button>');
    const i=document.getElementById("kwi"); if(i)i.onclick=signIn;
    const o=document.getElementById("kwo"); if(o)o.onclick=signOut;
  }
  async function init(){
    try{const {data:{session}}=await sb.auth.getSession(); user=session?session.user:null;}catch(e){}
    sb.auth.onAuthStateChange((_e,s)=>{user=s?s.user:null;renderAuth();refreshPro();if(user)pullRemote();});
    renderAuth(); refreshPro(); if(user) pullRemote();
  }
  if(document.readyState!=="loading") init(); else document.addEventListener("DOMContentLoaded",init);
})();
window.knowattRequirePro=function(){
  if(window.knowattIsPro) return true;
  if(confirm("This is a Knowatt Pro feature. Unlock the full question bank, all calculators, worked examples and cross-device sync?\n\nGo to upgrade page?")){
    location.href="/upgrade.html";
  }
  return false;
};
</script>

</body>
</html>
